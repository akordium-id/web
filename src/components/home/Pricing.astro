---
import { pricingTiers } from '../../data/pricing';
const featured = pricingTiers[0]; // Starter — featured left card
const options = pricingTiers;     // all three as right-side selectable options
---

<section id="pricing" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <p class="text-xs font-bold text-blue-600 uppercase tracking-widest mb-4">Harga</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-extrabold text-slate-900 leading-tight mb-4">
        Harga Fleksibel untuk<br class="hidden sm:block" /> Setiap Bisnis
      </h2>
      <p class="text-slate-500 text-sm max-w-xl mx-auto leading-relaxed">
        Di Akordium Lab, kami percaya pada transparansi harga. Paket kami cocok untuk semua bisnis — dari startup hingga enterprise.
      </p>
    </div>

    <!-- Main layout: featured card left + options right -->
    <div class="grid lg:grid-cols-2 gap-8 items-start">

      <!-- Left: Featured plan detail card -->
      <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-8 text-white shadow-2xl shadow-blue-100">
        <div class="inline-flex items-center gap-2 bg-white/15 rounded-full px-3 py-1 text-xs font-semibold mb-5">
          {featured.badge && <span>{featured.badge}</span>}
        </div>
        <h3 class="text-2xl font-bold mb-1">{featured.name} Plan</h3>
        <p class="text-blue-100 text-sm mb-6">{featured.descriptionId}</p>

        <ul class="space-y-3 mb-8">
          {featured.features.map(feat => (
            <li class={`flex items-center gap-3 text-sm ${feat.included ? 'text-white' : 'text-blue-300/60'}`}>
              <span class={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 ${feat.included ? 'bg-white/20' : 'bg-white/10'}`}>
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </span>
              {feat.text}
            </li>
          ))}
        </ul>

        <a
          href="/contact"
          class="block w-full text-center py-3.5 bg-white text-blue-700 font-bold rounded-xl hover:bg-blue-50 active:scale-95 transition-all"
        >
          {featured.ctaTextId}
        </a>
      </div>

      <!-- Right: Selectable pricing options -->
      <div class="space-y-4">
        {options.map((tier, i) => (
          <label class={`flex items-center gap-5 p-5 rounded-2xl border-2 cursor-pointer transition-all hover:border-blue-300 hover:shadow-md hover:-translate-y-0.5 ${
            i === 0 ? 'border-blue-500 bg-blue-50/50' : 'border-slate-100 bg-white'
          }`}>
            <!-- Radio -->
            <div class={`w-5 h-5 rounded-full border-2 flex items-center justify-center shrink-0 ${
              i === 0 ? 'border-blue-600' : 'border-slate-300'
            }`}>
              {i === 0 && <div class="w-2.5 h-2.5 rounded-full bg-blue-600"></div>}
            </div>

            <!-- Content -->
            <div class="flex-1 min-w-0">
              <p class="font-bold text-slate-900">{tier.name} Plan</p>
              <p class="text-slate-500 text-xs mt-0.5 line-clamp-1">{tier.descriptionId}</p>
              {tier.badge && (
                <span class="inline-block mt-1.5 px-2 py-0.5 bg-amber-100 text-amber-700 text-xs font-semibold rounded-full">
                  {tier.badge}
                </span>
              )}
            </div>

            <!-- Price -->
            <div class="text-right shrink-0">
              <p class="text-2xl font-extrabold text-slate-900">{tier.price}</p>
              {tier.period && <p class="text-xs text-slate-400">{tier.period}</p>}
              {!tier.period && <p class="text-xs text-slate-400">custom</p>}
            </div>
          </label>
        ))}

        <p class="text-xs text-slate-400 pt-2 px-1">
          Semua harga belum termasuk PPN. Hubungi kami untuk kebutuhan custom atau konsultasi gratis.
        </p>

        <a href="/contact" class="flex items-center justify-center gap-2 w-full py-3 bg-slate-900 text-white text-sm font-semibold rounded-xl hover:bg-blue-600 transition-colors mt-2">
          Diskusikan kebutuhan Anda
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
