---
import { services } from '../../data/services';

const icons: Record<string, string> = {
  code: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  server: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>`,
  academic: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>`,
};
---

<section id="services" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">
        Layanan Kami
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-4">
        Solusi IT Komprehensif<br />
        <span class="text-blue-600">untuk Bisnis Anda</span>
      </h2>
      <p class="text-slate-500 max-w-xl mx-auto">
        Kami menawarkan rangkaian layanan IT lengkap untuk membantu bisnis Anda tumbuh, aman, dan efisien di era digital.
      </p>
    </div>

    <!-- Cards -->
    <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
      {services.map((service) => (
        <div class="group relative bg-white rounded-2xl border border-slate-100 p-7 hover:border-blue-100 hover:shadow-xl hover:shadow-blue-50 hover:-translate-y-1 transition-all duration-300">
          <!-- Icon -->
          <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-5 group-hover:bg-blue-600 transition-colors duration-300">
            <div class="w-6 h-6 text-blue-600 group-hover:text-white transition-colors duration-300" set:html={icons[service.icon]} />
          </div>
          <!-- Content -->
          <h3 class="text-lg font-bold text-slate-900 mb-2">{service.titleId}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-5">{service.descriptionId}</p>
          <!-- Features -->
          <ul class="space-y-2 mb-6">
            {service.featuresId.map(feat => (
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="w-4 h-4 text-blue-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {feat}
              </li>
            ))}
          </ul>
          <!-- CTA -->
          <a
            href={`/services#${service.id}`}
            class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600 hover:text-blue-700 group/link"
          >
            Pelajari Lebih Lanjut
            <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      ))}
    </div>

    <div class="mt-10 text-center">
      <a href="/services" class="inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-800 transition-colors">
        Lihat Semua Layanan
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
