---
---

<section class="py-24 bg-slate-900 relative overflow-hidden">
  <!-- Subtle radial glow -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] rounded-full bg-blue-600/10 blur-3xl"></div>
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Logo mark -->
    <div class="flex items-center justify-center gap-2 mb-10">
      <div class="w-8 h-8 bg-blue-500 rounded-lg flex items-center justify-center">
        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
        </svg>
      </div>
      <span class="font-bold text-white text-lg tracking-tight">Akordium <span class="text-blue-400">Lab</span></span>
    </div>

    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4 leading-tight">
      Siap untuk Memulai<br />
      <span class="text-blue-400">Transformasi IT Anda?</span>
    </h2>
    <p class="text-slate-400 text-base mb-3">
      Biarkan Akordium Lab membantu Anda memanfaatkan potensi penuh teknologi — mulai dari keamanan, performa, hingga perencanaan jangka panjang.
    </p>
    <p class="text-slate-500 text-sm italic mb-10">
      Let IT help you unlock the full potential of your technology. Whether you need better security, improved performance, or long-term planning.
    </p>

    <a
      href="/contact"
      class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 active:scale-95 transition-all shadow-xl shadow-blue-900/30 text-sm"
    >
      Jadwalkan Konsultasi Gratis
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  </div>
</section>
