---
---

<section class="py-24 relative overflow-hidden bg-[#2f1d1b]">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-rose-900/30 blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 rounded-full bg-purple-900/20 blur-3xl"></div>
    <!-- Subtle dot grid -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 24px 24px;"></div>
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-xs font-bold text-rose-400 uppercase tracking-widest mb-6">Mulai dari satu titik</p>

    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-6 leading-tight">
      Punya proses yang terasa<br class="hidden sm:block" />
      makin berat?
    </h2>
    <p class="text-stone-300 text-base sm:text-lg mb-10 max-w-xl mx-auto leading-relaxed">
      Mari rapikan dari titik paling penting dulu. Konsultasi pertama gratis, tanpa komitmen.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-rose-900 font-bold rounded-xl hover:bg-rose-50 active:scale-95 transition-all shadow-xl text-sm w-full sm:w-auto"
      >
        Hubungi Kami
        <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Trust signals -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-6 text-stone-400 text-sm">
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-rose-400" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        Tanpa biaya awal
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-rose-400" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        Respon dalam 24 jam
      </span>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4 text-rose-400" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        7+ instansi aktif
      </span>
    </div>
  </div>
</section>
