---
---

<section class="relative overflow-hidden bg-linear-to-br from-white via-primary-50/40 to-rose-50/30 pt-20 pb-0">
  <!-- Background decorations -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-40 -right-40 w-150 h-150 rounded-full bg-primary-100/50 blur-3xl"></div>
    <div class="absolute top-1/2 -left-40 w-100 h-100 rounded-full bg-rose-100/40 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-20 items-center py-20 lg:py-28">

      <!-- Left: Copy -->
      <div>
        <!-- Badge -->
        <div class="eyebrow inline-flex items-center gap-2 bg-primary-600/10 border border-primary-200 rounded-full px-5 py-2 mb-10">
          <span class="w-1.5 h-1.5 rounded-full bg-primary-600 animate-pulse"></span>
          Solusi digital untuk bisnis Indonesia
        </div>

        <h1 class="font-sans text-5xl sm:text-6xl lg:text-[72px] font-bold text-stone-900 leading-[1.05] tracking-tight">
          Operasional lebih tertata, <span class="text-primary-600">bisnis tumbuh</span> lebih cepat.
        </h1>
        <p class="mt-8 text-lg sm:text-xl text-stone-600 leading-relaxed max-w-xl">
          Dari proses manual ke sistem digital yang terstruktur. Akordium membantu bisnis kecil-menengah menghemat waktu, mengurangi kesalahan, dan mengambil keputusan lebih cepat dengan data yang akurat.
        </p>

        <div class="mt-12 flex flex-col sm:flex-row items-start sm:items-center gap-5">
          <a href="/contact" class="btn-primary gap-2.5 px-8 py-4 text-base shadow-lg shadow-primary-200 hover:shadow-xl active:scale-[0.98]">
            Hubungi Kami
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/services" class="btn-secondary gap-2 px-8 py-4 text-base group">
            <svg class="w-4 h-4 transition-transform group-hover:scale-110" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Lihat Layanan Kami
          </a>
        </div>

      </div>

      <!-- Right: UI Mockup Cards on light background -->
      <div class="relative flex items-center justify-center min-h-125 sm:h-120 lg:h-135">

        <!-- Shadow base plate -->
        <div class="absolute inset-8 bg-white rounded-3xl shadow-2xl border border-stone-100"></div>

        <!-- Main card: Sales dashboard -->
        <div class="surface-card absolute top-4 right-4 w-[calc(100%-2rem)] max-w-[320px] sm:w-[320px] p-6">
          <div class="flex items-center justify-between mb-5">
            <p class="text-xs font-bold text-stone-500 uppercase tracking-wider">Ringkasan Penjualan</p>
            <span class="inline-flex items-center gap-1 text-xs text-emerald-700 bg-emerald-50 border border-emerald-100 px-2.5 py-1 rounded-full">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
              Live
            </span>
          </div>
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-primary-50 rounded-xl p-4">
              <p class="text-[11px] text-primary-600 font-semibold">Bulan Ini</p>
              <p class="text-2xl font-bold text-stone-900 mt-2">Rp 128jt</p>
              <p class="text-xs text-emerald-600 mt-1 font-semibold">↑ 12.4%</p>
            </div>
            <div class="bg-stone-50 rounded-xl p-4">
              <p class="text-[11px] text-stone-600 font-semibold">Transaksi</p>
              <p class="text-2xl font-bold text-stone-900 mt-2">384</p>
              <p class="text-xs text-emerald-600 mt-1 font-semibold">↑ 8.1%</p>
            </div>
          </div>
          <!-- Bar chart -->
          <div class="flex items-end gap-1 h-16">
            {[30, 55, 40, 70, 50, 85, 65, 80, 55, 90, 70, 100].map((h, i) => (
              <div class={`flex-1 rounded-sm ${i === 11 ? 'bg-primary-600' : 'bg-primary-200'}`} style={`height: ${h}%`}></div>
            ))}
          </div>
          <div class="flex justify-between mt-2">
            {['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'].map((m) => (
              <span class="text-[8px] text-stone-400 flex-1 text-center font-medium">{m[0]}</span>
            ))}
          </div>
        </div>

        <!-- Floating card: Inventory status -->
        <div class="surface-card absolute top-55 sm:top-37.5 lg:top-55 left-4 w-57.5 p-5">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 bg-primary-100 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
            </div>
            <div>
              <p class="text-xs font-bold text-stone-700">Stok Inventory</p>
              <p class="text-[11px] text-stone-400">Diperbarui 2m lalu</p>
            </div>
          </div>
          <div class="space-y-2.5">
            {[
              { label: "Produk A", pct: 82, color: "bg-primary-500" },
              { label: "Produk B", pct: 47, color: "bg-emerald-500" },
              { label: "Produk C", pct: 93, color: "bg-amber-500" },
            ].map((item) => (
              <div>
                <div class="flex justify-between mb-1.5">
                  <span class="text-[11px] text-stone-600 font-medium">{item.label}</span>
                  <span class="text-[11px] font-bold text-stone-700">{item.pct}%</span>
                </div>
                <div class="h-2 bg-stone-100 rounded-full overflow-hidden">
                  <div class={`h-full ${item.color} rounded-full`} style={`width: ${item.pct}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Notification badge -->
        <div class="surface-card absolute bottom-10 right-8 w-52.5 p-4 flex items-center gap-3">
          <div class="w-9 h-9 bg-emerald-100 rounded-lg flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-emerald-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-stone-800">Invoice dikirim</p>
            <p class="text-[11px] text-stone-500">PT. Maju Bersama · barusan</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Bottom divider into next section -->
    <div class="relative">
      <div class="h-20 bg-linear-to-b from-transparent to-stone-50"></div>
    </div>
  </div>
</section>
