---
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-slate-50 via-blue-50/30 to-white">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-100/50 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-cyan-100/40 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-blue-50/30 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Copy -->
      <div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight tracking-tight">
          Akordium,
          <br />
          <span class="text-blue-600">Sistem bisnis</span> lebih rapi
        </h1>
        <p class="mt-6 text-lg text-slate-600 leading-relaxed max-w-xl">
          Akordium membantu bisnis kecil-menengah merapikan operasional melalui website dan sistem informasi yang praktis, terstruktur, dan mudah dipakai sehari-hari.
        </p>
        <p class="mt-4 text-base text-slate-500 leading-relaxed max-w-xl">
          Kami membangun solusi web untuk membantu bisnis bekerja lebih tertata — mulai dari website company profile, dashboard internal, hingga management information system untuk penjualan, inventory, administrasi, maintenance, dan pelaporan.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 active:scale-95 transition-all shadow-lg shadow-blue-200">
            Hubungi kami
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/services" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-slate-700 font-semibold rounded-xl border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all">
            Hasil kami
          </a>
        </div>
      </div>

      <!-- Right: Illustration -->
      <div class="relative hidden lg:block">
        <!-- Main image -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-blue-100/60">
          <img
            src="https://images.unsplash.com/photo-1664575602554-2087b04935a5?w=800&auto=format&fit=crop&q=80"
            alt="Tim bisnis bekerja dengan sistem digital yang tertata"
            class="w-full h-[420px] object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/20 to-transparent"></div>
        </div>

        <!-- Floating card: operasional rapi -->
        <div class="absolute -bottom-5 -left-6 bg-white rounded-2xl shadow-xl shadow-slate-200/80 border border-slate-100 px-5 py-4 flex items-center gap-3 max-w-[220px]">
          <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-900 leading-tight">Operasional lebih rapi</p>
            <p class="text-xs text-slate-500 mt-0.5">Data terpusat, tim lebih fokus</p>
          </div>
        </div>

        <!-- Floating card: sistem praktis -->
        <div class="absolute -top-5 -right-4 bg-white rounded-2xl shadow-xl shadow-slate-200/80 border border-slate-100 px-5 py-4 flex items-center gap-3 max-w-[210px]">
          <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-900 leading-tight">Sistem yang langsung dipakai</p>
            <p class="text-xs text-slate-500 mt-0.5">Mudah dipelajari oleh tim</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
