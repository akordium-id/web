---
---

<section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-slate-50 via-blue-50/30 to-white">
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full bg-blue-100/50 blur-3xl"></div>
    <div class="absolute -bottom-20 -left-20 w-[400px] h-[400px] rounded-full bg-cyan-100/40 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] rounded-full bg-blue-50/30 blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-blue-50 border border-blue-100 rounded-full text-blue-700 text-sm font-medium mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
          Mitra Transformasi Digital Terpercaya
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 leading-tight tracking-tight">
          Teknologi Lebih
          <span class="text-blue-600"> Cerdas.</span>
          <br />
          Bisnis Lebih
          <span class="text-blue-600"> Kuat.</span>
        </h1>
        <p class="mt-6 text-lg text-slate-500 leading-relaxed max-w-lg">
          Kami menghadirkan solusi IT yang aman, modern, dan siap cloud untuk kebutuhan bisnis Anda — dari pengembangan aplikasi hingga infrastruktur enterprise.
        </p>
        <p class="mt-1 text-sm text-slate-400 italic">
          We deliver secure, cloud-ready, and future-proof technology solutions for your business needs.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 active:scale-95 transition-all shadow-lg shadow-blue-200">
            Konsultasi Gratis
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/services" class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-slate-700 font-semibold rounded-xl border border-slate-200 hover:border-slate-300 hover:bg-slate-50 transition-all">
            Lihat Layanan Kami
          </a>
        </div>
        <div class="mt-10 flex items-center gap-6 text-sm text-slate-500">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            No commitment
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Respons cepat
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            Tim berpengalaman
          </div>
        </div>
      </div>

      <!-- Right: Dashboard Widget -->
      <div class="relative hidden lg:block">
        <div class="relative bg-white rounded-2xl shadow-2xl shadow-blue-100/50 border border-slate-100 p-6 max-w-sm ml-auto">
          <!-- Header -->
          <div class="flex items-center justify-between mb-5">
            <div>
              <p class="text-xs text-slate-400 font-medium uppercase tracking-wide">Project Overview</p>
              <p class="text-lg font-bold text-slate-900">Q2 2026</p>
            </div>
            <div class="w-9 h-9 bg-blue-600 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
          </div>
          <!-- Chart bars -->
          <div class="flex items-end gap-2 h-24 mb-5">
            {[40, 65, 45, 80, 60, 90, 70].map((h, i) => (
              <div class="flex-1 rounded-t-md bg-blue-100 relative" style={`height:${h}%`}>
                {i === 5 && <div class="absolute inset-0 rounded-t-md bg-blue-600"></div>}
                {i !== 5 && <div class="absolute inset-0 rounded-t-md bg-blue-200"></div>}
              </div>
            ))}
          </div>
          <!-- Stats row -->
          <div class="grid grid-cols-3 gap-3">
            <div class="bg-slate-50 rounded-xl p-3 text-center">
              <p class="text-lg font-bold text-slate-900">200+</p>
              <p class="text-xs text-slate-500 mt-0.5">Proyek</p>
            </div>
            <div class="bg-blue-600 rounded-xl p-3 text-center">
              <p class="text-lg font-bold text-white">95%</p>
              <p class="text-xs text-blue-100 mt-0.5">Kepuasan</p>
            </div>
            <div class="bg-slate-50 rounded-xl p-3 text-center">
              <p class="text-lg font-bold text-slate-900">50+</p>
              <p class="text-xs text-slate-500 mt-0.5">Mitra</p>
            </div>
          </div>
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg shadow-slate-200/80 border border-slate-100 px-4 py-2.5 flex items-center gap-2">
          <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p class="text-xs font-semibold text-slate-800">Server Online</p>
            <p class="text-xs text-slate-400">Uptime 99.9%</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
