---
---

<section class="py-20 lg:py-28 bg-stone-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-xs font-bold text-rose-800 uppercase tracking-widest mb-4">Cara Kerja</p>
      <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-extrabold text-slate-900 leading-tight mb-4">
        Mulai dari Diskusi,<br class="hidden sm:block" />
        Selesai jadi Sistem yang Mandiri.
      </h2>
      <p class="text-slate-500 max-w-xl mx-auto leading-relaxed">
        Kami tidak hanya membangun aplikasi, kami merapikan alur kerja Anda lewat proses yang terukur dan transparan.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-3 gap-8 lg:gap-12 relative">
      <!-- Connecting line desktop -->
      <div class="hidden md:block absolute top-8 left-[16.66%] right-[16.66%] h-px bg-slate-200 z-0"></div>

      {[
        {
          step: "01",
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />`,
          title: "Kenalan dengan Cara Kerja Anda",
          desc: "Setiap bisnis punya cara unik. Kami tidak akan menawarkan solusi sebelum paham betul apa yang Anda butuhkan. Konsultasi pertama? Gratis dan tanpa komitmen.",
          color: "bg-rose-800",
        },
        {
          step: "02",
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
          title: "Cari Tahu Apa yang Menghambat",
          desc: "Sering merasa ada pekerjaan yang bolak-balik tapi hasilnya itu-itu saja? Kami bantu identifikasi masalahnya dan cari cara paling efisien untuk membereskannya.",
          color: "bg-purple-800",
        },
        {
          step: "03",
          icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />`,
          title: "Bangun Sistem yang \"Bernapas\"",
          desc: "Kami buatkan sistem yang fleksibel: cukup simpel untuk dipakai sekarang, tapi cukup kuat untuk tumbuh bersama bisnis Anda. Kami tetap di sini untuk menemani Anda setelah sistem rilis.",
          color: "bg-rose-900",
        },
      ].map((item) => (
        <div class="relative z-10 bg-white rounded-2xl border border-slate-100 p-8 shadow-sm hover:shadow-md transition-shadow">
          <!-- Step number + icon -->
          <div class="flex items-center gap-4 mb-6">
            <div class={`w-12 h-12 ${item.color} rounded-2xl flex items-center justify-center shrink-0 shadow-lg`}>
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={item.icon} />
              </svg>
            </div>
            <span class="text-4xl font-extrabold text-slate-400 leading-none">{item.step}</span>
          </div>

          <!-- Content -->
          <h3 class="font-bold text-slate-900 text-lg mb-3">{item.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-12 text-center">
      <a href="/contact" class="inline-flex items-center gap-2 text-sm font-semibold text-rose-800 hover:text-rose-900 group">
        Jadwalkan konsultasi gratis
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
