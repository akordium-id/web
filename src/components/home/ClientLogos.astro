---
const clientNames = [
  "Bank Mega",
  "Teavaro",
  "Orin GPS",
  "CV Andika Jaya",
  "Sabagya.co",
];
---

<section class="py-12 bg-stone-50 border-y border-stone-100">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    
    <!-- Compact trust band -->
    <div class="flex flex-col md:flex-row items-center justify-center md:justify-between gap-6 md:gap-10">
      
      <!-- Left: Headline -->
      <div class="text-center md:text-left">
        <p class="eyebrow text-xs mb-2">Klien Kami</p>
        <h3 class="font-sans text-xl sm:text-2xl font-bold text-stone-900">
          Dipercaya oleh mereka yang serius
        </h3>
      </div>

      <!-- Right: Client names -->
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        {clientNames.map((client) => (
          <span class="font-sans text-base sm:text-lg font-semibold text-primary-800">
            {client}
          </span>
        ))}
      </div>

    </div>
    
  </div>
</section>