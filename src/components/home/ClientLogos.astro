---
const trustMarkers = [
  { label: "7+ instansi", sublabel: "dipercaya" },
  { label: "Perbankan", sublabel: "hingga UMKM" },
  { label: "4× throughput", sublabel: "peningkatan rata-rata" },
  { label: "5+ tahun", sublabel: "pengalaman" },
];
---

<section class="py-12 bg-stone-50 border-y border-stone-100">
  <div class="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
    
    <!-- Compact trust band -->
    <div class="flex flex-col md:flex-row items-center justify-center md:justify-between gap-6 md:gap-10">
      
      <!-- Left: Headline -->
      <div class="text-center md:text-left">
        <p class="eyebrow text-xs mb-2">Rekam Jejak</p>
        <h3 class="font-sans text-xl sm:text-2xl font-bold text-stone-900">
          Dipercaya di berbagai industri
        </h3>
      </div>

      <!-- Right: Inline trust metrics -->
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-4">
        {trustMarkers.map((marker) => (
          <div class="text-center">
            <p class="font-sans text-lg sm:text-xl font-bold text-stone-900">{marker.label}</p>
            <p class="text-xs text-stone-500 mt-0.5">{marker.sublabel}</p>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>
