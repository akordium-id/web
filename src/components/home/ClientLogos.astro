---
const industries = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />`,
    label: "Perbankan & Keuangan",
    desc: "Otomasi proses operasional & web dashboard internal",
    count: 2,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />`,
    label: "GPS & Fleet Tracking",
    desc: "Migrasi sistem pelacakan armada ke arsitektur modern berperforma tinggi",
    count: 1,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z" />`,
    label: "Marketing Technology",
    desc: "Dashboard analitik pemasaran berbasis data untuk klien Eropa",
    count: 1,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    label: "Kontraktor & Infrastruktur",
    desc: "Sistem manajemen inventaris material multi-lokasi proyek konstruksi",
    count: 1,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />`,
    label: "Manajemen K3 & Safety",
    desc: "MIS pengelolaan APAR untuk distribusi, pemeliharaan, dan pelaporan",
    count: 1,
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
    label: "Wedding & Event",
    desc: "Dashboard internal pengelolaan produk dan pesanan seserahan",
    count: 1,
  },
];
---

<section class="py-16 bg-slate-950 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-slate-500 uppercase tracking-widest mb-3">Rekam jejak</p>
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white">
        Telah dipercaya di berbagai industri
      </h2>
      <p class="mt-3 text-slate-500 text-sm max-w-lg mx-auto leading-relaxed">
        Pengalaman langsung membangun sistem di 7+ instansi — dari perbankan nasional hingga bisnis lokal yang sedang tumbuh.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {industries.map((ind) => (
        <div class="group flex items-start gap-4 p-5 rounded-xl bg-white/3 border border-white/6 hover:bg-white/6 hover:border-white/10 transition-all">
          <div class="w-10 h-10 bg-blue-500/10 border border-blue-500/20 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-blue-500/15 transition-colors">
            <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={ind.icon} />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-200 mb-1">{ind.label}</p>
            <p class="text-xs text-slate-500 leading-relaxed">{ind.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom stat strip -->
    <div class="mt-10 pt-8 border-t border-white/5 flex flex-wrap justify-center gap-8 sm:gap-16 text-center">
      {[
        { num: "7+", label: "Instansi ditangani" },
        { num: "4×", label: "Peningkatan throughput" },
        { num: "5+", label: "Tahun pengalaman" },
      ].map((s) => (
        <div>
          <p class="text-2xl font-extrabold text-white">{s.num}</p>
          <p class="text-xs text-slate-500 mt-0.5">{s.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
