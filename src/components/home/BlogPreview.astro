---
import { blogPosts } from '../../data/blog';
const featured = blogPosts.slice(0, 4);
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
      <div>
        <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">
          Blog
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900">
          Insights & Inovasi
        </h2>
        <p class="text-slate-500 mt-2">
          Tips, strategi, dan berita terbaru dunia teknologi untuk bisnis Anda.
        </p>
      </div>
      <a href="/blog" class="shrink-0 inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-700 group">
        Semua Artikel
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {featured.map((post) => (
        <a href={`/blog/${post.slug}`} class="group block">
          <div class="rounded-xl overflow-hidden border border-slate-100 hover:border-blue-100 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="relative overflow-hidden aspect-video">
              <img
                src={post.image}
                alt={post.titleId}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute top-3 left-3">
                <span class="px-2 py-1 bg-blue-600 text-white text-xs font-semibold rounded-md">
                  {post.category}
                </span>
              </div>
            </div>
            <div class="p-4">
              <div class="flex items-center gap-2 text-xs text-slate-400 mb-2">
                <span>{post.date}</span>
                <span>·</span>
                <span>{post.readTime}</span>
              </div>
              <h3 class="text-sm font-bold text-slate-900 leading-snug mb-1 group-hover:text-blue-600 transition-colors">
                {post.titleId}
              </h3>
              <p class="text-xs text-slate-500 leading-relaxed line-clamp-2">{post.excerptId}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
