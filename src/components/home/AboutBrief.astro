---
import { stats } from '../../data/stats';
---

<section class="py-20 lg:py-28 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Left: Image/Illustration -->
      <div class="relative">
        <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-slate-200">
          <img
            src="https://images.unsplash.com/photo-1552664730-d307ca884978?w=700&auto=format&fit=crop&q=80"
            alt="Tim Akordium Lab bekerja bersama"
            class="w-full h-80 lg:h-[420px] object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-blue-900/20 to-transparent"></div>
        </div>
        <!-- Floating card -->
        <div class="absolute -right-4 -bottom-6 bg-white rounded-xl shadow-xl shadow-slate-200/80 border border-slate-100 p-4 hidden sm:block">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <div>
              <p class="text-sm font-bold text-slate-900">+40% Efisiensi</p>
              <p class="text-xs text-slate-500">Rata-rata penghematan klien kami</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Content -->
      <div>
        <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">
          Tentang Kami
        </span>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 leading-tight mb-4">
          Memberdayakan Bisnis Indonesia<br />
          <span class="text-blue-600">dengan Teknologi</span>
        </h2>
        <p class="text-slate-600 leading-relaxed mb-3">
          Di Akordium Lab, kami berspesialisasi dalam menghadirkan solusi IT yang sederhana, efisien, dan skalabel untuk bisnis modern. Mulai dari cloud infrastructure hingga sistem enterprise kompleks.
        </p>
        <p class="text-slate-500 text-sm leading-relaxed mb-8">
          <em>At Akordium Lab, we specialize in delivering simple, scalable, and effective IT solutions. From cloud infrastructure to complex enterprise systems — we've got you covered.</em>
        </p>

        <!-- Stats grid -->
        <div class="grid grid-cols-2 gap-4">
          {stats.map(stat => (
            <div class="bg-white rounded-xl p-4 border border-slate-100 hover:border-blue-100 hover:shadow-sm transition-all">
              <p class="text-2xl font-extrabold text-blue-600">{stat.value}</p>
              <p class="text-sm text-slate-500 mt-0.5">{stat.labelId}</p>
              <p class="text-xs text-slate-400 italic">{stat.label}</p>
            </div>
          ))}
        </div>

        <a href="/about" class="inline-flex items-center gap-2 mt-8 text-blue-600 font-semibold hover:text-blue-700 group">
          Pelajari Lebih Lanjut
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
