---
const valuePillars = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />`,
    color: "text-rose-700",
    bg: "bg-rose-50",
    label: "Delivery terstruktur",
    desc: "Proses jelas dari requirement sampai go-live. Anda tahu progress apa yang terjadi setiap minggu.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />`,
    color: "text-purple-700",
    bg: "bg-purple-50",
    label: "Disesuaikan kebutuhan",
    desc: "Bukan template generik. Kami bangun mengikuti workflow dan proses kerja bisnis Anda.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />`,
    color: "text-rose-700",
    bg: "bg-rose-50",
    label: "Langsung berdampak",
    desc: "Bukan sekedar website, tapi alat kerja yang menghemat waktu dan mengurangi chaos operasional.",
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
    color: "text-purple-700",
    bg: "bg-purple-50",
    label: "Teknologi yang tepat",
    desc: "Kami pilih stack yang proven dan maintainable, bukan yang hype. Keputusan teknis berdasarkan kebutuhan nyata Anda.",
  },
];
---

<section class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="grid lg:grid-cols-2 gap-16 items-center">

      <!-- Left: Value proposition -->
      <div>
        <p class="text-xs font-bold text-rose-800 uppercase tracking-widest mb-4">Kenapa Akordium Lab</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[44px] font-extrabold text-slate-900 leading-snug mb-6">
          Sistem yang <span class="text-rose-800">benar-benar dipakai,</span><br class="hidden sm:block" />
          bukan hanya dipasang.
        </h2>
        <p class="text-base text-slate-600 leading-relaxed mb-8 max-w-lg">
          Kami tidak membuat website untuk pajangan. Kami membangun sistem kerja yang tim Anda gunakan setiap hari, mulai dari order masuk, tracking proses, hingga laporan yang otomatis tersedia.
        </p>
        <a href="/services" class="inline-flex items-center gap-2 px-6 py-3 bg-rose-800 text-white text-sm font-semibold rounded-xl hover:bg-rose-900 active:scale-95 transition-all shadow-sm shadow-rose-200">
          Lihat pendekatan kami
          <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right: Value pillar cards -->
      <div class="space-y-4">
        {valuePillars.map((p) => (
          <div class="flex items-start gap-4 p-5 rounded-2xl border border-slate-200 bg-white hover:border-rose-200 hover:shadow-md hover:shadow-rose-50/40 transition-all">
            <div class={`w-10 h-10 ${p.bg} rounded-xl flex items-center justify-center shrink-0`}>
              <svg class={`w-5 h-5 ${p.color}`} aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={p.icon} />
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-800 mb-0.5">{p.label}</p>
              <p class="text-sm text-slate-600 leading-relaxed">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>
