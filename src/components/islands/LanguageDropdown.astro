---
---

<div class="relative inline-block">
  <button
    type="button"
    id="language-toggle"
    class="flex items-center gap-1 text-sm font-medium text-primary hover:text-secondary px-2 py-1"
    aria-haspopup="true"
    aria-expanded="false"
  >
    <span id="language-current">EN</span>
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      id="language-chevron"
      class="transition-transform"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  <div
    id="language-dropdown"
    class="hidden absolute right-0 mt-2 w-40 bg-white border border-gray-200 rounded-md shadow-lg z-50"
    role="menu"
  >
    <a
      href="/"
      class="language-option block w-full text-left px-4 py-2 text-sm text-primary hover:bg-gray-100 hover:text-secondary"
      data-lang="en"
      role="menuitem"
    >
      EN
    </a>
    <a
      href="/id/"
      class="language-option block w-full text-left px-4 py-2 text-sm text-primary hover:bg-gray-100 hover:text-secondary"
      data-lang="id"
      role="menuitem"
    >
      ID
    </a>
    <a
      href="/jv/"
      class="language-option block w-full text-left px-4 py-2 text-sm text-primary hover:bg-gray-100 hover:text-secondary"
      data-lang="jv"
      role="menuitem"
    >
      JW
    </a>
  </div>
</div>

<script>
  const languages: Record<string, string> = { en: "EN", id: "ID", jv: "JW" };

  function getLangFromPath(): string {
    const path = window.location.pathname;
    const segments = path.split("/").filter(Boolean);
    if (segments.length > 0 && ["en", "id", "jv"].includes(segments[0])) {
      return segments[0];
    }
    return "en";
  }

  function getLocalizedPath(lang: string): string {
    const path = window.location.pathname;
    const segments = path.split("/").filter(Boolean);
    if (segments.length > 0 && ["en", "id", "jv"].includes(segments[0])) {
      segments[0] = lang;
    } else {
      segments.unshift(lang);
    }
    if (lang === "en") {
      return "/" + segments.slice(1).join("/");
    }
    return "/" + segments.join("/");
  }

  function updateCurrentLang() {
    const currentLang = getLangFromPath();
    const el = document.getElementById("language-current");
    if (el) el.textContent = languages[currentLang] || "EN";
  }

  updateCurrentLang();

  const toggle = document.getElementById("language-toggle");
  const dropdown = document.getElementById("language-dropdown");
  const chevron = document.getElementById("language-chevron");

  toggle?.addEventListener("click", () => {
    const isOpen = dropdown?.classList.contains("hidden") === false;
    dropdown?.classList.toggle("hidden");
    toggle.setAttribute("aria-expanded", String(!isOpen));
    if (chevron) {
      chevron.classList.toggle("rotate-180");
    }
  });

  document.querySelectorAll(".language-option").forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const lang = (link as HTMLElement).dataset.lang || "en";
      const localizedPath = getLocalizedPath(lang);
      localStorage.setItem("preferredLanguage", lang);
      window.location.href = localizedPath;
    });
  });

  document.addEventListener("click", (e) => {
    if (toggle && dropdown && !toggle.contains(e.target as Node) && !dropdown.contains(e.target as Node)) {
      dropdown.classList.add("hidden");
      toggle.setAttribute("aria-expanded", "false");
      if (chevron) chevron.classList.remove("rotate-180");
    }
  });
</script>
