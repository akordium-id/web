---
interface Props {
  intro: string;
  firstValue: string;
  secondValue: string;
  thirdValue: string;
  divider: string;
  fourthValue: string;
  closure: string;
  team: string;
  trait: string;
  has: string;
  experience: string;
  fields: string;
}

const {
  intro = "We're not just another tech company. We're your digital partners, bringing together ",
  firstValue = "development expertise, ",
  secondValue = "strategic consulting, ",
  thirdValue = "reliable hosting, ",
  divider = "and ",
  fourthValue = "results-driven marketing ",
  closure = "to help your business thrive online.",
  team = "Our team of ",
  trait = "passionate tech enthusiasts ",
  has = "has ",
  experience = "3+ years of experience ",
  fields = "creating digital solutions for banking, marketing, and IoT fields.",
} = Astro.props;
---

<section class="py-12 bg-base-muted">
  <div class="container mx-auto px-4">
    <p class="text-primary/90 max-w-4xl mx-auto text-center text-lg">
      {intro}
      <span class="font-semibold text-secondary">{firstValue}</span>
      <span class="font-semibold text-secondary">{secondValue}</span>
      <span class="font-semibold text-secondary">{thirdValue}</span>
      {divider}
      <span class="text-tertiary font-semibold">{fourthValue}</span>
      {closure}
    </p>
    <div class="mt-8 text-center">
      <p class="text-primary/80">
        {team}
        <span class="font-semibold text-accent">{trait}</span>
        {has}
        <span class="text-tertiary font-semibold">{experience}</span>
        {fields}
      </p>
    </div>
  </div>
</section>
