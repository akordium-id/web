---
interface TestimonialItem {
  quote: string;
  author: string;
  position: string;
  image: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  testimonials?: TestimonialItem[];
}

const {
  title = "What Our Clients Say",
  subtitle = "Real feedback from real people we've worked with",
  testimonials = [
    {
      quote: "They didn't just build us a website, they built us a digital presence that transformed our business. The team was responsive, creative, and actually fun to work with!",
      author: "Sarah Johnson",
      position: "Marketing Director, TechStart",
      image: "https://i.pravatar.cc/150?img=1",
    },
    {
      quote: "Our app launch was a huge success thanks to the development and marketing support from this team. They understood our vision and made it even better than we imagined!",
      author: "Michael Chen",
      position: "Founder, HeadTrack",
      image: "https://i.pravatar.cc/150?img=3",
    },
    {
      quote: "The consulting services we received helped us navigate a complex digital transformation. Their hosting solutions have been rock-solid, with 99.9% uptime as promised.",
      author: "Jessica Williams",
      position: "CTO, RetailPlus",
      image: "https://i.pravatar.cc/150?img=4",
    },
    {
      quote: "Outstanding service and technical expertise. They delivered our project ahead of schedule and exceeded all expectations.",
      author: "David Miller",
      position: "CEO, InnovateCo",
      image: "https://i.pravatar.cc/150?img=5",
    },
    {
      quote: "Their team's attention to detail and commitment to quality is remarkable. Best tech partner we've ever worked with!",
      author: "Emma Thompson",
      position: "Product Manager, CloudSys",
      image: "https://i.pravatar.cc/150?img=6",
    },
  ],
} = Astro.props;

const testimonialsJson = JSON.stringify(testimonials);
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-primary mb-2">{title}</h2>
      <p class="text-gray-600">{subtitle}</p>
    </div>
    <div id="testimonial-grid" class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.slice(0, 3).map((testimonial) => (
        <div class="testimonial-card bg-gray-50 p-6 rounded-lg hover:shadow-lg transition-all duration-500">
          <div class="flex text-yellow-400 mb-4">
            {[...Array(5)].map((_, i) => (
              <svg key={i} class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-gray-600 italic mb-4">"{testimonial.quote}"</p>
          <div class="flex items-center">
            <img src={testimonial.image} alt={testimonial.author} class="w-10 h-10 rounded-full mr-3 object-cover" loading="lazy" />
            <div>
              <p class="font-semibold text-primary">{testimonial.author}</p>
              <p class="text-sm text-gray-500">{testimonial.position}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const testimonials: Array<{ quote: string; author: string; position: string; image: string }> = JSON.parse(Astro.props.testimonials || "[]");
  if (testimonials.length <= 3) {
    // Not enough testimonials to rotate
  } else {
    let activeIndices = [0, 1, 2];
    let isTransitioning = false;

    const grid = document.getElementById("testimonial-grid");
    if (!grid) return;

    function renderTestimonials(indices: number[]) {
      const fragment = document.createDocumentFragment();
      indices.forEach((testimonialIndex) => {
        const testimonial = testimonials[testimonialIndex];
        const card = document.createElement("div");
        card.className = "testimonial-card bg-gray-50 p-6 rounded-lg hover:shadow-lg transition-all duration-500";
        card.innerHTML = `
          <div class="flex text-yellow-400 mb-4">
            ${[...Array(5)].map(() => `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>`).join("")}
          </div>
          <p class="text-gray-600 italic mb-4">"${testimonial.quote}"</p>
          <div class="flex items-center">
            <img src="${testimonial.image}" alt="${testimonial.author}" class="w-10 h-10 rounded-full mr-3 object-cover" loading="lazy" />
            <div>
              <p class="font-semibold text-primary">${testimonial.author}</p>
              <p class="text-sm text-gray-500">${testimonial.position}</p>
            </div>
          </div>
        `;
        fragment.appendChild(card);
      });

      grid.innerHTML = "";
      grid.appendChild(fragment);
    }

    function rotateTestimonials() {
      if (isTransitioning) return;
      isTransitioning = true;

      const existingCards = grid.querySelectorAll(".testimonial-card");
      existingCards.forEach((card) => {
        card.style.opacity = "0";
        card.style.transform = "translateY(20px)";
      });

      setTimeout(() => {
        const unusedIndices = Array.from(Array(testimonials.length).keys()).filter((i) => !activeIndices.includes(i));
        const newRandomIndex = unusedIndices[Math.floor(Math.random() * unusedIndices.length)];
        activeIndices = [...activeIndices.slice(1), newRandomIndex];
        renderTestimonials(activeIndices);
        isTransitioning = false;
      }, 500);
    }

    setInterval(rotateTestimonials, 5000);
  }
</script>
