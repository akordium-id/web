---
interface Props {
  tagline: string;
  heading: string;
  subheading: string;
  ctaText: string;
  ctaHref?: string;
  workText: string;
  workHref?: string;
}

const {
  tagline = "Software Company",
  heading = "Your Digital Partner for Growth",
  subheading = "Secure and reliable • Result-driven approach • Fast-paced development • Professional",
  ctaText = "Book a Call",
  ctaHref = "/contact",
  workText = "See Our Work",
  workHref = "#",
} = Astro.props;
---

<section class="bg-base to-base-muted py-12 md:py-24 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto text-center space-y-6 md:space-y-8">
      <span class="inline-block text-sm md:text-base text-primary/80 font-medium mb-2">
        {tagline}
      </span>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-primary leading-tight">
        {heading}
      </h1>
      <p class="text-gray-700 text-lg md:text-xl max-w-2xl mx-auto">
        {subheading}
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={ctaHref}
          class="bg-tertiary hover:bg-tertiary-light text-white rounded-full px-3 py-2 md:px-5 md:py-3 text-base md:text-lg transition-colors"
        >
          {ctaText}
        </a>
        <a
          href={workHref}
          class="border-2 border-primary text-primary hover:bg-primary hover:text-white rounded-full px-3 py-2 md:px-5 md:py-3 text-base md:text-lg font-medium transition-colors"
        >
          {workText}
        </a>
      </div>
    </div>
  </div>
</section>
