---
interface Props {
  title?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  whatsappText?: string;
  whatsappHref?: string;
}

const {
  title = "Let's Create Something Amazing Together",
  description = "Ready to take your digital presence to the next level? We're here to help you build, optimize, and grow your online business.",
  ctaText = "Contact us",
  ctaHref = "/contact",
  whatsappText = "WhatsApp",
  whatsappHref = "http://wa.me/628159988995?text=Hello,%20I%20would%20like%20to%20consult%20with%20you...",
} = Astro.props;
---

<section class="bg-secondary/10 py-16">
  <div class="container mx-auto px-4 text-center">
    <h2 class="text-4xl font-bold mb-4 text-primary">{title}</h2>
    <p class="text-lg mb-8 max-w-2xl mx-auto text-primary">{description}</p>
    <div class="flex gap-4 justify-center">
      <a
        href={ctaHref}
        class="bg-tertiary text-white px-5 py-2 rounded-full hover:bg-tertiary-light transition-colors"
      >
        {ctaText}
      </a>
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="border border-tertiary text-tertiary px-5 py-2 rounded-full hover:bg-tertiary/10 transition-colors"
      >
        {whatsappText}
      </a>
    </div>
  </div>
</section>
