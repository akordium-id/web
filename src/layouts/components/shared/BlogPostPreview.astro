---
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";

interface Post {
  href: string;
  title: string;
  date: Date;
  snippet: string;
  image?: string;
  category?: string;
  readTime?: number;
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("en-US", {
  day: "2-digit",
  month: "long",
  year: "numeric",
}).format(post.date).toUpperCase();
---

<article class="group">
  <div class="border-border-dark/12 grid gap-6 border-b py-8 md:py-10 lg:grid-cols-[minmax(0,1.35fr)_300px_120px] lg:items-center lg:gap-10 xl:grid-cols-[minmax(0,1.5fr)_360px_140px] xl:gap-14">
    <div class="space-y-5">
      <div class="text-text-default/65 flex flex-wrap items-center gap-2 text-xs font-semibold tracking-[0.18em] uppercase">
        {post.category && <span>{post.category}</span>}
        {post.category && <span class="text-text-default/35">.</span>}
        <time datetime={post.date.toISOString()}>{formattedDate}</time>
      </div>

      <div class="space-y-3">
        <h2 class="text-dark text-2xl font-semibold leading-tight md:text-3xl">
          <a href={post.href} class="group-hover:text-primary transition-colors">
            {post.title}
          </a>
        </h2>

        <p class="text-text-default/70 line-clamp-2 max-w-2xl text-sm leading-6 md:text-base">
          {post.snippet}
        </p>
      </div>
    </div>

    <a href={post.href} class="relative block overflow-hidden rounded-sm">
      {post.image ? (
        <OptimizedImage
          src={post.image}
          alt={post.title}
          width={720}
          height={430}
          class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-103 lg:h-38 xl:h-42"
        />
      ) : (
        <div class="from-primary/15 via-primary/8 to-theme-light h-52 w-full bg-linear-to-br lg:h-38 xl:h-42" />
      )}
    </a>

    <div class="flex items-center justify-between gap-4 lg:justify-end">
      {post.readTime && (
        <span class="text-text-default/75 text-sm font-medium">{post.readTime} min read</span>
      )}

      <a
        href={post.href}
        aria-label={post.title}
        class="bg-dark text-text-inverse hover:bg-primary inline-flex size-14 items-center justify-center rounded-full transition-colors duration-300">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M9 7h8v8" />
        </svg>
      </a>
    </div>
  </div>
</article>
