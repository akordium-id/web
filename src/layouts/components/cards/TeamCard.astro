---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

type Props = { member: CollectionEntry<"team"> };
const { member } = Astro.props;
const { title, profession, image } = member.data;
const { Content } = await render(member);
---

<div
  class="border-border rounded-2xl border bg-white p-6 text-center transition-shadow hover:shadow-md">
  {
    image ? (
      <div class="mx-auto mb-4 size-24 overflow-hidden rounded-full bg-theme-light">
        <img
          src={image}
          alt={title}
          class="size-full object-cover"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="bg-primary/10 mx-auto mb-4 flex size-24 items-center justify-center rounded-full">
        <span class="text-primary text-2xl font-bold">
          {title.charAt(0)}
        </span>
      </div>
    )
  }
  <h3 class="font-semibold">{title}</h3>
  {profession && <p class="text-primary mt-1 text-sm">{profession}</p>}
  <div class="text-text-default/70 prose prose-sm mx-auto mt-2 max-w-none">
    <Content />
  </div>
</div>
