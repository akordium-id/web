---
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";
import SectionBadge from "@/layouts/components/global/SectionBadge.astro";
import SectionTitle from "@/layouts/components/global/SectionTitle.astro";

type FaqItem = { question: string; answer: string };
type FaqCategory = { name: string; items: FaqItem[] };
type Props = Record<string, unknown>;

const defaultContent = (
  await getEntryCTM("sections", "faq-main", Astro.currentLocale)
)?.data as any;

const { enable, badge, title, categories } = overrideObjects(
  { ...defaultContent },
  Astro.props,
) as typeof defaultContent;

if (!enable) return;
---

<section class="section-spacing-vertical">
  <div class="container">
    <div class="mb-12 max-w-xl" data-aos="fade-up" data-aos-duration="600">
      {badge && <SectionBadge title={badge} />}
      {title && <SectionTitle title={title} />}
    </div>

    <div class="grid grid-cols-1 gap-12 lg:grid-cols-3">
      <!-- Category Nav -->
      <aside class="hidden lg:block" data-aos="fade-up" data-aos-duration="600">
        <nav class="sticky top-24 space-y-2">
          {
            (categories as FaqCategory[])?.map((cat, i) => (
              <a
                href={`#faq-cat-${i}`}
                class="text-text-default/60 hover:text-primary block rounded-lg px-3 py-2 text-sm transition-colors hover:bg-theme-light">
                {cat.name}
              </a>
            ))
          }
        </nav>
      </aside>

      <!-- FAQ Items -->
      <div class="lg:col-span-2 space-y-12">
        {
          (categories as FaqCategory[])?.map((cat, catIdx) => (
            <div id={`faq-cat-${catIdx}`}>
              <h2 class="mb-4 text-lg font-semibold" data-aos="fade-up" data-aos-duration="600">
                {cat.name}
              </h2>
              <div class="space-y-3">
                {cat.items.map((item, i) => (
                  <details
                    class="border-border rounded-xl border bg-white"
                    data-aos="fade-up"
                    data-aos-delay={i * 40}
                    data-aos-duration="600">
                    <summary class="cursor-pointer px-5 py-4 font-medium select-none">
                      {item.question}
                    </summary>
                    <div class="text-text-default/70 border-border border-t px-5 py-4 text-sm leading-relaxed">
                      {item.answer}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
