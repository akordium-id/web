---
import { getCollection } from "astro:content";
import TeamCard from "@/layouts/components/cards/TeamCard.astro";
import SectionBadge from "@/layouts/components/global/SectionBadge.astro";
import SectionTitle from "@/layouts/components/global/SectionTitle.astro";

interface Props {
  badge?: string;
  title?: string;
}

const { badge = "Our Team", title = "Meet the People Behind Akordium" } =
  Astro.props;

const team = await getCollection("team", ({ data }) => !data.draft);
team.sort((a, b) => (a.data.weight ?? 99) - (b.data.weight ?? 99));

if (team.length === 0) return;
---

<section class="section-spacing-vertical bg-theme-light">
  <div class="container">
    <div class="mb-12 max-w-xl" data-aos="fade-up" data-aos-duration="600">
      <SectionBadge title={badge} />
      <SectionTitle title={title} />
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        team.map((member, i) => (
          <div
            data-aos="fade-up"
            data-aos-delay={i * 80}
            data-aos-duration="600">
            <TeamCard member={member} />
          </div>
        ))
      }
    </div>
  </div>
</section>
