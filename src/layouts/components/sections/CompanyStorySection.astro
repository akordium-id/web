---
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";
import SectionBadge from "@/layouts/components/global/SectionBadge.astro";
import SectionTitle from "@/layouts/components/global/SectionTitle.astro";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import Button from "@/components/Button.astro";
import { markdownify } from "@/lib/utils/textConverter";

type Props = Record<string, unknown>;

const defaultContent = (
  await getEntryCTM("sections", "about-story", Astro.currentLocale)
)?.data as any;

const { enable, badge, title, description, image, imageAlt, button: btn } =
  overrideObjects({ ...defaultContent }, Astro.props) as typeof defaultContent;

if (!enable) return;
---

<section class="section-spacing-vertical overflow-hidden">
  <div
    class="container grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16 xl:gap-24">
    <!-- Text -->
    <div class="flex flex-col gap-6" data-aos="fade-up" data-aos-duration="600">
      {badge && <SectionBadge title={badge} />}
      {title && <SectionTitle title={title} />}
      {
        description && (
          <div
            class="text-text-default/70 leading-relaxed"
            set:html={markdownify(description, true)}
          />
        )
      }
      {
        btn?.enable && (
          <div>
            <Button
              variant={btn.variant || "fill"}
              label={btn.label}
              url={btn.url}
              icon={btn.icon}
              class="btn-primary"
            />
          </div>
        )
      }
    </div>

    <!-- Image -->
    {
      image && (
        <div
          class="relative"
          data-aos="fade-up"
          data-aos-delay="150"
          data-aos-duration="600">
          <OptimizedImage
            src={image}
            alt={imageAlt || title || "About Akordium"}
            class="w-full rounded-2xl object-cover"
            width={600}
            height={480}
          />
        </div>
      )
    }
  </div>
</section>
