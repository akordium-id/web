---
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects";
import SectionBadge from "@/layouts/components/global/SectionBadge.astro";
import SectionTitle from "@/layouts/components/global/SectionTitle.astro";

type Package = {
  name: string;
  from: string;
  description: string;
  highlights: string[];
  cta_url: string;
  featured: boolean;
};
type Props = Record<string, unknown>;

const defaultContent = (
  await getEntryCTM("sections", "pricing-main", Astro.currentLocale)
)?.data as any;

const { enable, badge, title, subtitle, packages, note } = overrideObjects(
  { ...defaultContent },
  Astro.props,
) as typeof defaultContent;

if (!enable) return;
const lang = Astro.currentLocale || "en";
---

<section class="section-spacing-vertical">
  <div class="container">
    <div class="mb-12 max-w-2xl" data-aos="fade-up" data-aos-duration="600">
      {badge && <SectionBadge title={badge} />}
      {title && <SectionTitle title={title} />}
      {subtitle && <p class="text-text-default/70 mt-4 leading-relaxed">{subtitle}</p>}
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        (packages as Package[])?.map((pkg, i) => (
          <div
            class:list={[
              "border rounded-2xl flex flex-col",
              pkg.featured
                ? "border-primary bg-primary text-white shadow-lg shadow-primary/30"
                : "border-border bg-white",
            ]}
            data-aos="fade-up"
            data-aos-delay={i * 80}
            data-aos-duration="600">
            {pkg.featured && (
              <div class="rounded-t-2xl bg-white/20 px-5 py-2 text-center text-xs font-semibold uppercase tracking-wider">
                {lang === "id" ? "Paling Populer" : "Most Popular"}
              </div>
            )}
            <div class="flex flex-1 flex-col p-6">
              <h3 class="mb-1 font-semibold">{pkg.name}</h3>
              <p
                class:list={[
                  "mb-2 text-2xl font-bold",
                  pkg.featured ? "text-white" : "text-primary",
                ]}>
                {pkg.from}
              </p>
              <p
                class:list={[
                  "mb-4 text-sm leading-relaxed",
                  pkg.featured ? "text-white/80" : "text-text-default/60",
                ]}>
                {pkg.description}
              </p>
              <ul class="mb-6 flex-1 space-y-2">
                {pkg.highlights.map((h: string) => (
                  <li class="flex items-start gap-2 text-sm">
                    <span
                      class:list={[
                        "mt-0.5 shrink-0",
                        pkg.featured ? "text-white" : "text-primary",
                      ]}>
                      ✓
                    </span>
                    <span
                      class:list={[
                        pkg.featured ? "text-white/90" : "",
                      ]}>
                      {h}
                    </span>
                  </li>
                ))}
              </ul>
              <a
                href={pkg.cta_url}
                class:list={[
                  "rounded-xl px-4 py-2 text-center text-sm font-semibold transition-colors",
                  pkg.featured
                    ? "bg-white text-primary hover:bg-white/90"
                    : "bg-primary text-white hover:bg-primary/90",
                ]}>
                {lang === "id" ? "Hubungi Kami" : "Get Started"}
              </a>
            </div>
          </div>
        ))
      }
    </div>

    {
      note && (
        <p
          class="text-text-default/60 mt-8 text-center text-sm"
          data-aos="fade-up"
          data-aos-delay="200">
          * {note}
        </p>
      )
    }
  </div>
</section>
