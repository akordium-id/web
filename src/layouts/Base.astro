---
import "aos/dist/aos.css";
import "@/styles/global.css";
import Head from "@/components/global/Head.astro";
import Header from "@/components/global/Header.astro";
import Footer from "@/components/global/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  showHeader?: boolean;
  showFooter?: boolean;
  noIndex?: boolean;
  canonical?: string;
  structuredData?: Record<string, unknown>;
  status?: number;
}

const {
  title,
  description,
  keywords,
  showHeader = true,
  showFooter = true,
  noIndex = false,
  canonical,
  structuredData,
  status,
} = Astro.props;

const menuItems = [
  { label: "Home", href: "/" },
  { label: "Services", href: "/services/" },
  { label: "Blog", href: "/blog/" },
  { label: "Contact", href: "/contact/" },
];
---

<!doctype html>
<html lang={Astro.currentLocale || "en"}>
  <Head
    title={title}
    description={description}
    keywords={keywords}
    noIndex={noIndex}
    canonical={canonical}
    structuredData={structuredData}
  />
  <body>
    {showHeader && <Header menuItems={menuItems} />}
    <main class:list={["has-section-gap", Astro.props.class]}>
      <slot />
    </main>
    {showFooter && <Footer />}
  </body>
</html>
