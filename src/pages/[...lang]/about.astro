---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import CompanyStorySection from "@/layouts/components/sections/CompanyStorySection.astro";
import StatsSection from "@/layouts/components/sections/StatsSection.astro";
import ValuesSection from "@/layouts/components/sections/ValuesSection.astro";
import TeamSection from "@/layouts/components/sections/TeamSection.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import { generatePaths, useTranslations } from "@/lib/utils/i18nUtils";

export function getStaticPaths() {
  return generatePaths();
}

const lang = Astro.currentLocale || "en";
const t = await useTranslations(lang);

const title = lang === "id" ? "Tentang Kami" : "About Us";
const description =
  lang === "id"
    ? "Kenali Akordium — tim, nilai, dan komitmen kami untuk kesuksesan digital Anda."
    : "Learn about Akordium — our team, values, and commitment to your digital success.";
---

<Base {title} {description}>
  <PageHeader {title} breadcrumbTitle={title} />
  <CompanyStorySection />
  <StatsSection />
  <ValuesSection />
  <TeamSection
    badge={lang === "id" ? "// TIM KAMI" : "// OUR TEAM"}
    title={lang === "id"
      ? "Orang-orang di Balik Akordium"
      : "Meet the People Behind Akordium"}
  />
  <ContactSection />
</Base>
