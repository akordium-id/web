---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import PricingSection from "@/layouts/components/sections/PricingSection.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import { generatePaths } from "@/lib/utils/i18nUtils";

export function getStaticPaths() {
  return generatePaths();
}

const lang = Astro.currentLocale || "en";
const title = lang === "id" ? "Harga Layanan" : "Service Pricing";
const description =
  lang === "id"
    ? "Harga transparan dan terjangkau untuk semua kebutuhan digital bisnis Anda."
    : "Transparent, affordable pricing for all your business digital needs.";
---

<Base {title} {description}>
  <PageHeader {title} breadcrumbTitle={title} />
  <PricingSection />
  <ContactSection />
</Base>
