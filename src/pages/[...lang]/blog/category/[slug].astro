---
import Base from "@/layouts/Base.astro";
import BlogPostPreview from "@/components/shared/BlogPostPreview.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { slugifyyy } from "@/lib/utils/textConverter";
import { generatePaths, getEntrySlugCTM, getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const langPaths = generatePaths();

  const localizedCategoryGroups = await Promise.all(
    langPaths.map(async (langPath) => ({
      lang: langPath.params.lang,
      categories: await getTaxonomy("blog", "categories", langPath.params.lang),
    })),
  );

  return localizedCategoryGroups.flatMap(({ lang, categories }) =>
    categories.map((category) => ({
      params: {
        lang,
        slug: category.slug,
      },
      props: {
        categoryName: category.name,
      },
    })),
  );
}

const lang = Astro.currentLocale || "en";
const t = await useTranslations(lang);
const { categoryName } = Astro.props;
const currentSlug = Astro.params.slug || "";

const posts = await getCollection("blog");
const sortedPosts = posts
  .filter(
    (post) =>
      !post.data.draft &&
      (post.data.categories || []).some(
        (category) => slugifyyy(category) === currentSlug,
      ),
  )
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  });

const categories = await getTaxonomy("blog", "categories", lang);

const getReadTime = (content: string) =>
  Math.max(1, Math.ceil(content.split(/\s+/).filter(Boolean).length / 200));
---

<Base title={`${categoryName} - ${t("blog.title") || "Blog"}`}>
  <PageHeader title={t("blog.heading") || "Blog"} breadcrumbTitle={categoryName} />

  <section class="section-spacing-vertical">
    <div class="container space-y-12 lg:space-y-16">
      <div
        class="scrollbar-hide flex flex-nowrap items-center gap-6 overflow-x-auto border-b pb-5 text-sm font-medium whitespace-nowrap lg:justify-center lg:gap-10"
        data-aos="fade-up"
        data-aos-duration="600">
        <a
          href={getLocaleUrlCTM("/blog", Astro.currentLocale)}
          class="text-text-default/80 hover:text-dark transition-colors">
          {t("button.showAll") || "Show All"}
        </a>

        {categories.map((category) => (
          <a
            href={getLocaleUrlCTM(`/${category.slug}`, Astro.currentLocale, "/blog/category")}
            class:list={[
              "transition-colors hover:underline underline-offset-8",
              category.slug === currentSlug
                ? "decoration-dark underline"
                : "text-text-default/80 hover:text-dark",
            ]}>
            {category.name}
          </a>
        ))}
      </div>

      {sortedPosts.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 xl:gap-7.5">
          {sortedPosts.map((post, i) => (
            <div data-aos="fade-up" data-aos-delay={i * 80} data-aos-duration="600">
              <BlogPostPreview
                post={{
                  href: getEntrySlugCTM(post, Astro.currentLocale),
                  title: post.data.title,
                  date: post.data.date || new Date(),
                  snippet: post.data.snippet || post.data.description || "",
                  image: post.data.image,
                  category: post.data.categories?.[0],
                  readTime: getReadTime(post.body || ""),
                }}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="text-text-default/60 py-12 text-center">{t("blog.noPosts") || "No blog posts found."}</p>
      )}
    </div>
  </section>

  <ContactSection />
</Base>