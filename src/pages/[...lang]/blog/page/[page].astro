---
import Base from "@/layouts/Base.astro";
import BlogPostPreview from "@/components/shared/BlogPostPreview.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import Pagination from "@/layouts/components/widgets/Pagination.astro";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import { generatePaths, getEntrySlugCTM, getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils";
import { slugifyyy } from "@/lib/utils/textConverter";
import { getCollection } from "astro:content";

const pageSize = 2;
const brandLogos = [
  { name: "Amazon", src: "/images/customers/brands/amazon.webp" },
  { name: "Slack", src: "/images/customers/brands/slack.webp" },
  { name: "Google", src: "/images/customers/brands/google.webp" },
  { name: "LinkedIn", src: "/images/customers/brands/linkedin.webp" },
  { name: "Walmart", src: "/images/customers/brands/walmart.webp" },
];

export async function getStaticPaths() {
  const pageSize = 2;
  const posts = await getCollection("blog");
  const publishedPosts = posts.filter((post) => !post.data.draft);
  const totalPages = Math.ceil(publishedPosts.length / pageSize);
  const langPaths = generatePaths();

  return langPaths.flatMap((langPath) =>
    Array.from({ length: Math.max(totalPages - 1, 0) }, (_, index) => ({
      params: {
        lang: langPath.params.lang,
        page: String(index + 2),
      },
    })),
  );
}

const lang = Astro.currentLocale || "en";
const t = await useTranslations(lang);
const currentPage = Number(Astro.params.page || "1");

const posts = await getCollection("blog");
const sortedPosts = posts
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
    const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
    return dateB - dateA;
  });

const totalPages = Math.ceil(sortedPosts.length / pageSize);
const indexOfLastPost = currentPage * pageSize;
const indexOfFirstPost = indexOfLastPost - pageSize;
const visiblePosts = sortedPosts.slice(indexOfFirstPost, indexOfLastPost);

const categories = Array.from(
  new Set(sortedPosts.flatMap((post) => post.data.categories || [])),
);

const getReadTime = (content: string) =>
  Math.max(1, Math.ceil(content.split(/\s+/).filter(Boolean).length / 200));
---

<Base title={t("blog.title") || "Blog"}>
  <PageHeader title={t("blog.heading") || "Blog"} />

  <section class="section-spacing-vertical">
    <div class="container space-y-12 lg:space-y-16">
      {categories.length > 0 && (
        <div
          class="scrollbar-hide flex flex-nowrap items-center gap-6 overflow-x-auto border-b pb-5 text-sm font-medium whitespace-nowrap lg:justify-center lg:gap-10"
          data-aos="fade-up"
          data-aos-duration="600">
          <a
            href={getLocaleUrlCTM("/blog", Astro.currentLocale)}
            class="decoration-dark underline-offset-8 transition-colors hover:underline">
            {t("button.showAll") || "Show All"}
          </a>

          {categories.map((category) => (
            <a
              href={getLocaleUrlCTM(`/${slugifyyy(category)}`, Astro.currentLocale, "/blog/category")}
              class="text-text-default/80 hover:text-dark transition-colors">
              {category}
            </a>
          ))}
        </div>
      )}

      {visiblePosts.length > 0 ? (
        <div class="divide-border-dark/12 border-border-dark/12 divide-y border-y">
          {visiblePosts.map((post, i) => (
            <div data-aos="fade-up" data-aos-delay={i * 80} data-aos-duration="600">
              <BlogPostPreview
                post={{
                  href: getEntrySlugCTM(post, Astro.currentLocale),
                  title: post.data.title,
                  date: post.data.date || new Date(),
                  snippet: post.data.snippet || post.data.description || "",
                  image: post.data.image,
                  category: post.data.categories?.[0],
                  readTime: getReadTime(post.body || ""),
                }}
              />
            </div>
          ))}
        </div>
      ) : (
        <p class="text-text-default/60 py-12 text-center">{t("blog.noPosts") || "No blog posts found."}</p>
      )}

      <Pagination collection="blog" currentPage={currentPage} totalPages={totalPages} class="pt-2 md:pt-6" />

      <section class="space-y-8 pt-2 md:pt-8">
        <div class="flex items-center gap-6">
          <div class="border-border-dark/12 h-px flex-1 border-t"></div>
          <p class="text-text-default/80 text-center text-xl font-medium">
            From startups to the world's largest companies
          </p>
          <div class="border-border-dark/12 h-px flex-1 border-t"></div>
        </div>

        <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-5">
          {brandLogos.map((brand) => (
            <div class="border-border-dark/12 flex min-h-18 items-center justify-center rounded-xl border bg-white px-4 py-5 shadow-[0_8px_30px_rgba(0,0,0,0.02)]">
              <OptimizedImage
                src={brand.src}
                alt={brand.name}
                width={133}
                height={32}
                class="h-8 w-auto object-contain"
              />
            </div>
          ))}
        </div>
      </section>
    </div>
  </section>

  <ContactSection />
</Base>