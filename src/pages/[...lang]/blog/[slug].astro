---
import Base from "@/layouts/Base.astro";
import { generatePaths, getEntryRouteParam } from "@/lib/utils/i18nUtils";
import { getCollection, render } from "astro:content";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import ContactSection from "@/components/sections/ContactSection.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const langPaths = generatePaths();

  return posts.flatMap((post) =>
    langPaths.map((langPath) => ({
      params: {
        lang: langPath.params.lang,
        slug: getEntryRouteParam(post),
      },
      props: {
        post,
      },
    }))
  );
}

const { post } = Astro.props;
if (!post) {
  return Astro.redirect("/404");
}

const { Content } = await render(post);
const formattedDate = post.data.date
  ? new Intl.DateTimeFormat("en-US", { dateStyle: "long" }).format(post.data.date)
  : "";
---

<Base
  title={post.data.title}
  description={post.data.description || post.data.snippet}
>
  <PageHeader title={post.data.title} breadcrumbTitle={post.data.title} />

  <section class="section-spacing-vertical">
    <div class="container max-w-4xl">
      {formattedDate && (
        <time class="text-text-default/60 mb-8 block text-sm">{formattedDate}</time>
      )}
      <div class="prose prose-lg max-w-none">
        <Content />
      </div>
    </div>
  </section>

  <ContactSection />
</Base>
