---
import Base from "@/layouts/Base.astro";
import ContactForm from "@/components/islands/ContactForm.astro";
import { generatePaths, useTranslations } from "@/lib/utils/i18nUtils";

export function getStaticPaths() {
  return generatePaths();
}

const lang = Astro.currentLocale || "en";
const t = await useTranslations(lang);
---

<Base title={t("contact.title") || "Contact Us - Akordium Lab"} description={t("contact.description")}>
  <section class="py-16 bg-base">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4">{t("contact.heading") || "Hubungi Kami"}</h1>
        <p class="text-gray-600 max-w-2xl mx-auto">{t("contact.subheading") || "We'd love to hear from you. Get in touch with us using the form below or through our contact information."}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <div>
          <ContactForm />
        </div>

        <div>
          <div class="bg-white p-8 rounded-lg shadow-lg">
            <h2 class="text-2xl font-bold text-primary mb-6">{t("contact.info.title") || "Business Information"}</h2>

            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-tertiary/10 rounded-lg flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-primary">{t("contact.info.company") || "Akordium Lab"}</h3>
                  <p class="text-gray-600 text-sm mt-1">Jl. Pagesangan Agung I/84, Surabaya, Jawa Timur, 60233</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-tertiary/10 rounded-lg flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-primary">{t("contactInfo.phoneLabel") || "Phone Number"}</h3>
                  <a href="tel:+628159988995" class="text-gray-600 text-sm mt-1 hover:text-tertiary transition-colors">+62 815-9988-995</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-tertiary/10 rounded-lg flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-primary">{t("contactInfo.emailLabel") || "Email"}</h3>
                  <a href="mailto:hello@akordium.id" class="text-gray-600 text-sm mt-1 hover:text-tertiary transition-colors">hello@akordium.id</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
