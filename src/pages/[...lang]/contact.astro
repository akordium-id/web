---
import Base from "@/layouts/Base.astro";
import PageHeader from "@/layouts/components/widgets/PageHeader.astro";
import ContactSection from "@/components/sections/ContactSection.astro";
import Icons from "@/helpers/Icons.astro";
import { generatePaths, useTranslations } from "@/lib/utils/i18nUtils";

export function getStaticPaths() {
  return generatePaths();
}

const lang = Astro.currentLocale || "en";
const t = await useTranslations(lang);
const contactCards = [
  {
    icon: "MailOpen",
    title: "E-mail Address",
    value: "hello@akordium.id",
  },
  {
    icon: "Phone",
    title: "Phone Number",
    value: "+62 815-9988-995",
  },
  {
    icon: "Link",
    title: "Our Location",
    value: "Surabaya, East Java, Indonesia",
  },
];

const ticker = Array.from({ length: 12 }, () => "Let's Talk");
---

<Base title={t("contact.title") || "Contact Us"} description={t("contact.description")}>
  <PageHeader
    title={t("contact.heading") || "Contact Us"}
    breadcrumbTitle={t("contact.heading") || "Contact Us"}
  />

  <section class="section-spacing-vertical pb-0">
    <div class="container">
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
        {contactCards.map((card, i) => (
          <article
            class="bg-theme-light border-border-dark/10 rounded-xl border px-6 py-8 text-center md:px-8 md:py-9"
            data-aos="fade-up"
            data-aos-delay={i * 90}
            data-aos-duration="600">
            <div class="text-primary mx-auto mb-5 inline-flex size-16 items-center justify-center">
              <Icons icon={card.icon} class="h-10 w-10" />
            </div>
            <h2 class="text-h4 text-dark font-semibold">{card.title}</h2>
            <p class="text-text-default/70 mt-3 leading-7">{card.value}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <ContactSection hasSectionSpacing={false} />

  <section class="pt-0">
    <iframe
      title="Akordium office location"
      src="https://www.openstreetmap.org/export/embed.html?bbox=112.711%2C-7.333%2C112.761%2C-7.283&layer=mapnik"
      class="h-[500px] w-full"
      loading="lazy"
    />
  </section>

  <section class="section-spacing-vertical pt-0">
    <div
      class="marquee bg-white border-border-dark/12 relative overflow-hidden border-y"
      style="--marquee-elements: 12; --marquee-element-width: 260px; --marquee-duration: 22s; --marquee-reverse: ;">
      <div class="marquee-content flex marquee-element-width-auto">
        {ticker.map((label, i) => (
          <div class="flex min-w-[260px] items-center justify-center gap-8 py-7">
            <span class="text-text-default/50 text-4xl leading-none">○</span>
            <span
              class:list={[
                "text-6xl font-semibold uppercase leading-none md:text-7xl",
                i % 3 === 1
                  ? "text-dark"
                  : "text-transparent [-webkit-text-stroke:1px_#1f222b]",
              ]}>
              {label}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
