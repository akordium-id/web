---
import Layout from '../layouts/Layout.astro';

const accessKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
---

<Layout title="Kontak | Akordium Lab" description="Hubungi tim Akordium Lab untuk konsultasi IT gratis. Kami siap membantu transformasi digital bisnis Anda.">
  <!-- Hero -->
  <section class="py-20 bg-gradient-to-br from-stone-50 to-rose-50/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-rose-50 text-rose-800 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">Kontak</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mb-4 leading-tight">
        Mari Bicara<br />
        <span class="text-rose-800">Tentang Kebutuhan IT Anda</span>
      </h1>
      <p class="text-lg text-slate-500 max-w-xl mx-auto">
        Konsultasi pertama gratis. Tim kami siap merespons dalam 1×24 jam kerja.
      </p>
    </div>
  </section>

  <!-- Contact section -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold text-slate-900 mb-6">Kirim Pesan</h2>

          <!-- Success banner, shown via JS when ?success=true -->
          <div
            id="form-success"
            class="hidden mb-5 p-4 bg-green-50 border border-green-200 rounded-xl flex items-start gap-3"
            role="alert"
          >
            <svg class="w-5 h-5 text-green-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <div>
              <p class="font-semibold text-green-800 text-sm">Pesan berhasil terkirim!</p>
              <p class="text-green-700 text-sm mt-0.5">Tim kami akan menghubungi Anda dalam 1×24 jam kerja.</p>
            </div>
          </div>

          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-5"
          >
            <input type="hidden" name="access_key" value={accessKey} />
            <!-- redirect URL ditetapkan secara dinamis oleh script di bawah agar bekerja di semua environment -->
            <input type="hidden" id="redirect-field" name="redirect" value="" />
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="name" class="block text-sm font-medium text-slate-700 mb-1.5">Nama Lengkap <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="John Doe"
                  class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-rose-700 focus:border-transparent transition-all text-sm"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">Email <span class="text-red-500">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="email@perusahaan.com"
                  class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-rose-700 focus:border-transparent transition-all text-sm"
                />
              </div>
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-slate-700 mb-1.5">Nomor WhatsApp / Telepon</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+62 812 3456 7890"
                  class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-rose-700 focus:border-transparent transition-all text-sm"
              />
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-slate-700 mb-1.5">Layanan yang Diminati</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-700 focus:outline-none focus:ring-2 focus:ring-rose-700 focus:border-transparent transition-all text-sm bg-white"
              >
                <option value="">Pilih layanan...</option>
                <option value="web-app">Web & App Development</option>
                <option value="infrastructure">Infrastructure & Hosting Support</option>
                <option value="training">Training Services</option>
                <option value="other">Lainnya / Belum Tahu</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 mb-1.5">Pesan <span class="text-red-500">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                rows={5}
                placeholder="Ceritakan kebutuhan IT Anda atau pertanyaan yang ingin Anda ajukan..."
                class="w-full px-4 py-2.5 rounded-xl border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-rose-700 focus:border-transparent transition-all text-sm resize-none"
              ></textarea>
            </div>
            <!-- hCaptcha, dikelola otomatis oleh Web3Forms client script -->
            <div class="h-captcha" data-captcha="true"></div>

            <button
              type="submit"
              class="w-full py-3.5 bg-rose-800 text-white font-semibold rounded-xl hover:bg-rose-900 active:scale-95 transition-all text-sm shadow-lg shadow-rose-200"
            >
              Kirim Pesan
            </button>
            <p class="text-xs text-slate-400 text-center">
              Dengan mengirim pesan ini, Anda menyetujui bahwa kami akan menghubungi Anda kembali melalui kontak yang diberikan.
            </p>
          </form>
        </div>

        <!-- Info sidebar -->
        <div class="lg:col-span-2 space-y-6">
          <h2 class="text-2xl font-bold text-slate-900">Informasi Kontak</h2>

          <div class="space-y-4">
            <div class="flex items-start gap-4 p-4 bg-slate-50 rounded-xl border border-slate-100">
              <div class="w-10 h-10 bg-rose-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-rose-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-slate-900 text-sm mb-0.5">Alamat</p>
                <p class="text-slate-500 text-sm">Jl. Pagesangan Agung I/84<br />Surabaya, Jawa Timur 60233</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-slate-50 rounded-xl border border-slate-100">
              <div class="w-10 h-10 bg-rose-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-rose-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-slate-900 text-sm mb-0.5">Email</p>
                <a href="mailto:hello@akordium.id" class="text-rose-800 hover:text-rose-900 text-sm">hello@akordium.id</a>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-slate-50 rounded-xl border border-slate-100">
              <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-slate-900 text-sm mb-0.5">WhatsApp</p>
                <a href="https://wa.me/628159988995" target="_blank" rel="noopener noreferrer" class="text-green-600 hover:text-green-700 text-sm">+62 815-9988-995</a>
              </div>
            </div>

            <div class="flex items-start gap-4 p-4 bg-slate-50 rounded-xl border border-slate-100">
              <div class="w-10 h-10 bg-rose-50 rounded-xl flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-rose-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-slate-900 text-sm mb-0.5">Jam Operasional</p>
                <p class="text-slate-500 text-sm">Senin – Jumat: 09.00 – 17.00 WIB<br />Sabtu: 09.00 – 13.00 WIB</p>
              </div>
            </div>
          </div>

          <div class="p-5 bg-[#2f1d1b] rounded-2xl text-white">
            <p class="font-bold mb-1">Butuh Respons Cepat?</p>
            <p class="text-rose-200 text-sm mb-4">Hubungi kami langsung via WhatsApp untuk respons lebih cepat.</p>
            <a
              href="https://wa.me/628159988995?text=Halo%20Akordium%20Lab%2C%20saya%20ingin%20konsultasi%20IT"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-white text-rose-900 font-semibold rounded-lg text-sm hover:bg-rose-50 transition-colors"
            >
              <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Chat WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script is:inline src="https://web3forms.com/client/script.js" async defer></script>
<script>
  // Set redirect URL dinamis agar berfungsi di semua environment (localhost & production)
  const redirectField = document.getElementById('redirect-field') as HTMLInputElement | null;
  if (redirectField) {
    redirectField.value = window.location.origin + '/contact?success=true';
  }

  // Tampilkan banner sukses jika di-redirect balik dengan ?success=true
  if (new URLSearchParams(window.location.search).get('success') === 'true') {
    const banner = document.getElementById('form-success');
    if (banner) {
      banner.classList.remove('hidden');
      banner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    // Bersihkan query string dari URL tanpa reload
    window.history.replaceState({}, '', window.location.pathname);
  }
</script>
