---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
  }));
}

const { slug } = Astro.params;
const posts = await getCollection("blog");
const post = posts.find(p => p.data.slug === slug);

if (!post) return Astro.redirect("/blog");

const { Content } = await render(post);
const relatedPosts = posts
  .filter(p => p.data.slug !== slug)
  .sort(() => Math.random() - 0.5)
  .slice(0, 3);
---

<Layout title={`${post.data.titleId} | Akordium Lab Blog`} description={post.data.excerptId}>
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="max-w-3xl mx-auto mb-12">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-primary-700 transition-colors mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
          Kembali ke Blog
        </a>

        <span class="inline-block px-3 py-1 bg-primary-500/10 border border-primary-500/20 text-primary-400 text-xs font-semibold rounded-full uppercase tracking-wider mb-5">
          {post.data.category}
        </span>

        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mb-4 leading-tight">
          {post.data.titleId}
        </h1>
        <p class="text-lg text-slate-500 italic mb-6">{post.data.title}</p>

        <div class="flex flex-wrap items-center gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center">
              <span class="text-rose-800 font-bold text-sm">{post.data.author.charAt(0)}</span>
            </div>
            <div>
              <span class="text-sm font-semibold text-slate-700 block">{post.data.author}</span>
              <span class="text-xs text-slate-400">Author</span>
            </div>
          </div>
          <div class="hidden sm:block w-px h-8 bg-slate-200"></div>
          <div class="flex items-center gap-3 text-sm text-slate-400">
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              {post.data.date}
            </div>
            <span class="w-1 h-1 rounded-full bg-slate-300"></span>
            <div class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              {post.data.readTime}
            </div>
          </div>
        </div>
      </div>

      <!-- Featured Image -->
      <div class="max-w-5xl mx-auto mb-12">
        <img
          src={post.data.image}
          alt={post.data.titleId}
          class="w-full h-64 sm:h-80 lg:h-[28rem] object-cover rounded-2xl shadow-xl shadow-slate-200 border border-slate-200"
          loading="lazy"
        />
      </div>

      <!-- Article Content -->
      <div class="max-w-3xl mx-auto">
        <div class="prose prose-slate prose-lg max-w-none">
          <p class="text-xl text-slate-600 font-medium mb-8 leading-relaxed border-l-4 border-rose-700 pl-6 bg-slate-50 py-4 rounded-r-xl">
            {post.data.excerptId}
          </p>
          <Content />
        </div>

        <!-- Author Bio -->
        <div class="mt-16 p-6 lg:p-8 bg-slate-50 rounded-2xl border border-slate-100">
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center shrink-0">
              <span class="text-rose-800 font-bold text-lg">{post.data.author.charAt(0)}</span>
            </div>
            <div>
              <h3 class="font-bold text-slate-900 text-lg mb-1">{post.data.author}</h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-3">
                Tim pengembang dan konsultan IT di Akordium Lab, membantu bisnis Indonesia berkembang melalui solusi teknologi modern.
              </p>
              <a href="/about" class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
                Lihat profil tim
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-10 p-6 lg:p-8 bg-slate-50 rounded-2xl border border-slate-100">
          <h3 class="font-bold text-slate-900 text-xl mb-2">Tertarik mendiskusikan hal ini lebih lanjut?</h3>
          <p class="text-slate-500 text-sm mb-5 leading-relaxed">Tim kami siap membantu Anda mengimplementasikan solusi yang dibahas dalam artikel ini. Konsultasi gratis tersedia.</p>
          <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-rose-800 text-white font-bold rounded-xl hover:bg-rose-700 transition-all">
            Hubungi Kami
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>

        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
          <div class="mt-20">
            <h3 class="text-2xl font-extrabold text-slate-900 mb-2">Artikel Terkait</h3>
            <p class="text-slate-500 text-sm mb-8">Artikel lain yang mungkin Anda sukai.</p>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {relatedPosts.map(related => (
                <a href={`/blog/${related.data.slug}`} class="group block">
                  <div class="bg-white rounded-2xl overflow-hidden border border-slate-100 hover:border-primary-200 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="relative overflow-hidden aspect-[16/10]">
                      <img
                        src={related.data.image}
                        alt={related.data.titleId}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                      />
                      <div class="absolute top-3 left-3">
                        <span class="px-2 py-1 bg-rose-800 text-white text-xs font-semibold rounded-lg shadow-sm">
                          {related.data.category}
                        </span>
                      </div>
                    </div>
                    <div class="p-5">
                      <div class="flex items-center gap-2 text-sm text-slate-400 mb-2">
                        <span>{related.data.date}</span>
                        <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                        <span>{related.data.readTime}</span>
                      </div>
                      <h4 class="font-bold text-slate-900 text-base leading-snug group-hover:text-primary-700 transition-colors line-clamp-2">
                        {related.data.titleId}
                      </h4>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>
</Layout>
