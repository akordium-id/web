---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
  }));
}

const { slug } = Astro.params;
const posts = await getCollection("blog");
const post = posts.find(p => p.data.slug === slug);

if (!post) return Astro.redirect("/blog");

const { Content } = await render(post);
---

<Layout title={`${post.data.titleId} | Akordium Lab Blog`} description={post.data.excerptId}>
  <section class="py-12 bg-slate-50 border-b border-slate-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="mb-4">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-primary-700 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
          </svg>
          Kembali ke Blog
        </a>
      </div>
      <span class="inline-block px-2.5 py-1 bg-primary-600 text-white text-xs font-semibold rounded-lg mb-3">{post.data.category}</span>
      <h1 class="text-3xl sm:text-4xl font-extrabold text-slate-900 mb-4 leading-tight">{post.data.titleId}</h1>
      <p class="text-lg text-slate-500 italic mb-4">{post.data.title}</p>
      <div class="flex items-center gap-3 text-sm text-slate-400">
        <span>Akordium Lab Team</span>
        <span>·</span>
        <span>{post.data.date}</span>
        <span>·</span>
        <span>{post.data.readTime}</span>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 mt-8">
    <img
      src={post.data.image}
      alt={post.data.titleId}
      class="w-full h-64 sm:h-80 object-cover rounded-2xl shadow-lg shadow-slate-200"
      loading="lazy"
    />
  </div>

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <div class="prose prose-slate prose-lg max-w-none">
      <p class="text-xl text-slate-600 font-medium mb-6 leading-relaxed">{post.data.excerptId}</p>
      <Content />
    </div>

    <div class="mt-12 p-6 bg-primary-50 rounded-2xl border border-primary-200">
      <h3 class="font-bold text-slate-900 mb-2">Tertarik mendiskusikan hal ini lebih lanjut?</h3>
      <p class="text-slate-600 text-sm mb-4">Tim kami siap membantu Anda mengimplementasikan solusi yang dibahas dalam artikel ini.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white font-semibold rounded-xl hover:bg-primary-700 transition-all text-sm">
        Hubungi Kami
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </article>
</Layout>
