---
import Layout from '../../layouts/Layout.astro';
import { blogPosts } from '../../data/blog';
---

<Layout title="Blog — Akordium Lab" description="Artikel, tips, dan insights seputar teknologi IT untuk bisnis Indonesia dari tim Akordium Lab.">
  <!-- Hero -->
  <section class="py-20 bg-gradient-to-br from-slate-50 to-blue-50/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">Blog</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mb-4">
        Insights & Inovasi
      </h1>
      <p class="text-lg text-slate-500 max-w-xl mx-auto">
        Tips teknologi, strategi digital, dan berita terbaru dari tim Akordium Lab untuk membantu bisnis Anda berkembang.
      </p>
    </div>
  </section>

  <!-- Posts grid -->
  <section class="py-16 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {blogPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block">
            <div class="rounded-2xl overflow-hidden border border-slate-100 hover:border-blue-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
              <div class="relative overflow-hidden aspect-video">
                <img
                  src={post.image}
                  alt={post.titleId}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute top-3 left-3">
                  <span class="px-2.5 py-1 bg-blue-600 text-white text-xs font-semibold rounded-lg">{post.category}</span>
                </div>
              </div>
              <div class="p-5">
                <div class="flex items-center gap-2 text-xs text-slate-400 mb-3">
                  <span>{post.date}</span>
                  <span>·</span>
                  <span>{post.readTime}</span>
                </div>
                <h2 class="font-bold text-slate-900 text-lg leading-snug mb-2 group-hover:text-blue-600 transition-colors">
                  {post.titleId}
                </h2>
                <p class="text-slate-500 text-sm leading-relaxed line-clamp-2">{post.excerptId}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
