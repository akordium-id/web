---
import Layout from '../layouts/Layout.astro';
import { stats } from '../data/stats';

const values = [
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Jujur & Transparan",
    description: "Tidak ada klaim yang dibesar-besarkan. Kami menyampaikan apa yang bisa dan tidak bisa kami lakukan — sejak awal.",
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Fokus pada Dampak",
    description: "Setiap keputusan teknis kami dasarkan pada manfaat nyata bagi operasional bisnis — bukan sekadar teknologi yang terlihat canggih.",
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    title: "Kode yang Terawat",
    description: "Kami menulis kode yang bisa dibaca, diuji, dan dikembangkan lagi — bukan sekadar yang berjalan hari ini.",
  },
];

const experiences = [
  { year: "2020–2022", role: "IT Developer", place: "Bank Mega", desc: "Otomasi proses treasury & banking dengan UiPath RPA, web Mega Open API & dashboard statistik." },
  { year: "2022–2023", role: "Backend Developer (Part-time)", place: "Kontraktor Infrastruktur", desc: "Sistem inventaris material multi-lokasi untuk proyek konstruksi jalan dan jembatan." },
  { year: "2023–2024", role: "Backend Developer", place: "Teavaro (UK, remote)", desc: "Refactor arsitektur backend marketing tech, test coverage 75%, Go & PostgreSQL." },
  { year: "2025–kini", role: "Backend Developer", place: "Vastel (Orin GPS)", desc: "Migrasi sistem GPS tracker ke Go + PostgreSQL + TimescaleDB; 8.000 tps, 3 TB/bulan." },
  { year: "2026–kini", role: "Founder & Developer", place: "PT Akordium Digital Berkah", desc: "MIS-APAR untuk CV Andika Jaya Infinite, dashboard internal @sabagya.co, dan layanan klien lainnya." },
];

const philosophyPillars = [
  {
    symbol: "♩",
    title: "Akordeon — Harmoni dua tangan",
    body: "Akordeon dimainkan dengan dua tangan: satu untuk melodi, satu untuk harmoni. Keduanya harus bergerak bersama agar musik terdengar baik. Begitu juga cara kami bekerja — pengetahuan bisnis Anda dan keahlian teknis kami harus selaras untuk menghasilkan sistem yang benar-benar berguna.",
    accent: "border-blue-500/30 bg-blue-500/5",
    symbolColor: "text-blue-400",
  },
  {
    symbol: "⚗",
    title: "Lab — Jujur dan iteratif",
    body: "Laboratorium bukan tempat yang serba sempurna — tapi tempat di mana masalah diteliti dengan jujur, hipotesis diuji, dan kesalahan menjadi bahan pelajaran. Kami membawa semangat itu ke setiap proyek: tidak ada janji besar, tapi ada proses yang disiplin dan bisa dipertanggungjawabkan.",
    accent: "border-emerald-500/30 bg-emerald-500/5",
    symbolColor: "text-emerald-400",
  },
  {
    symbol: "✦",
    title: "Berkah — Teknologi yang bermanfaat",
    body: "Teknologi hanya sebaik manfaat yang ia bawa. Sistem terbaik bukan yang paling canggih, tapi yang paling membantu tim bekerja lebih mudah setiap harinya. Kami percaya bahwa pekerjaan baik yang dilakukan dengan niat baik akan menghasilkan sesuatu yang berkelanjutan.",
    accent: "border-amber-500/30 bg-amber-500/5",
    symbolColor: "text-amber-400",
  },
];
---

<Layout title="Tentang Kami — Akordium Lab" description="Kenali Akordium Lab lebih dalam — studio IT kecil yang fokus pada sistem bisnis yang benar-benar bekerja.">

  <!-- Hero -->
  <section class="relative py-24 lg:py-32 bg-slate-950 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_0%,rgba(37,99,235,0.10),transparent)]"></div>
      <div class="absolute inset-0 opacity-[0.025]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-semibold rounded-full uppercase tracking-wider mb-5">Tentang Akordium</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white mb-6 leading-tight">
        Studio IT kecil yang bikin<br />
        <span class="text-blue-400">sistem bisnis beneran jalan</span>
      </h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        Akordium bukan korporasi besar. Kami adalah studio pendiri tunggal yang bergerak dengan pengalaman langsung di perbankan, SaaS, GPS tracking, dan sistem informasi bisnis.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">
        <!-- Left: foto + stats -->
        <div class="space-y-6">
          <img
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=700&auto=format&fit=crop&q=80"
            alt="Akordium Lab workspace"
            class="rounded-2xl shadow-xl shadow-slate-200 w-full h-72 lg:h-80 object-cover"
            loading="lazy"
          />
          <div class="grid grid-cols-2 gap-3">
            {stats.map(stat => (
              <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                <p class="text-2xl font-extrabold text-blue-600">{stat.value}</p>
                <p class="text-xs text-slate-500 mt-0.5">{stat.labelId}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: narasi -->
        <div class="pt-2">
          <p class="text-sm font-semibold text-blue-600 uppercase tracking-wider mb-4">Cerita kami</p>
          <h2 class="text-3xl font-extrabold text-slate-900 mb-5 leading-snug">
            Dibangun dari pengalaman lapangan, bukan asumsi
          </h2>
          <div class="space-y-4 text-slate-600 leading-relaxed text-base">
            <p>
              Akordium lahir dari perjalanan 5+ tahun mengerjakan sistem nyata — otomasi proses di bank nasional, backend SaaS pemasaran untuk klien Eropa, migrasi GPS tracker dengan jutaan data poin per hari, hingga MIS operasional untuk bisnis lokal.
            </p>
            <p>
              Pengalaman itu mengajarkan satu hal: bisnis bukan kekurangan teknologi, tapi sering kekurangan <em>sistem yang tepat untuk skalanya</em>. Solusi enterprise terlalu berat, tapi spreadsheet sudah tidak cukup.
            </p>
            <p>
              Akordium hadir di tengah itu — membangun sistem yang langsung bisa dipakai, terawat dengan baik, dan bisa tumbuh bersama bisnis.
            </p>
          </div>

          <!-- Founder callout -->
          <div class="mt-8 flex items-start gap-4 p-5 rounded-2xl bg-slate-50 border border-slate-100">
            <div class="w-12 h-12 rounded-xl bg-blue-600 flex items-center justify-center text-white font-bold text-base shrink-0">FN</div>
            <div>
              <p class="text-sm font-bold text-slate-900">Faiq Najib Al-Aziz</p>
              <p class="text-xs text-slate-500 mt-0.5">Pendiri & Backend Developer — M.Kom. Sistem Informasi ITS</p>
              <p class="text-xs text-slate-400 mt-2 leading-relaxed">
                Go · PostgreSQL · Laravel · TimescaleDB · Redis · UiPath RPA · Docker
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-20 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-14">
        <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">Di balik nama</p>
        <h2 class="text-3xl font-extrabold text-white mb-4">Mengapa "Akordium Lab"?</h2>
        <p class="text-slate-400 leading-relaxed">
          Nama ini bukan sekadar branding. Ada cara pandang di dalamnya tentang bagaimana kami ingin bekerja bersama klien.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-5">
        {philosophyPillars.map((p) => (
          <div class={`rounded-2xl border p-7 ${p.accent}`}>
            <span class={`text-3xl font-serif ${p.symbolColor} block mb-5`}>{p.symbol}</span>
            <h3 class="text-base font-bold text-white mb-3">{p.title}</h3>
            <p class="text-sm text-slate-400 leading-relaxed">{p.body}</p>
          </div>
        ))}
      </div>

      <!-- Closing note -->
      <div class="mt-10 max-w-2xl mx-auto text-center">
        <p class="text-slate-500 text-sm leading-relaxed">
          Singkatnya: kami ingin ikut <span class="text-slate-300 font-medium">bernapas bersama proses bisnis Anda</span> — bukan datang, serahkan sistem, lalu pergi.
          Seperti akordeon yang hanya berbunyi indah kalau dua tangannya bekerja bersama.
        </p>
      </div>
    </div>
  </section>

  <!-- Experience timeline -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-blue-600 uppercase tracking-wider mb-3">Rekam jejak</p>
        <h2 class="text-3xl font-extrabold text-slate-900">Pengalaman yang membentuk Akordium</h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4">
        {experiences.map((exp, i) => (
          <div class="flex gap-5 items-start">
            <div class="flex flex-col items-center shrink-0">
              <div class="w-3 h-3 rounded-full bg-blue-500 mt-1.5 ring-4 ring-blue-100"></div>
              {i < experiences.length - 1 && <div class="w-px flex-1 bg-slate-200 mt-1 min-h-[36px]"></div>}
            </div>
            <div class="pb-6">
              <div class="flex flex-wrap items-baseline gap-2 mb-1">
                <span class="text-xs font-semibold text-blue-600 bg-blue-50 px-2 py-0.5 rounded-full">{exp.year}</span>
                <span class="text-sm font-bold text-slate-900">{exp.role}</span>
                <span class="text-xs text-slate-400">· {exp.place}</span>
              </div>
              <p class="text-sm text-slate-500 leading-relaxed">{exp.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold text-blue-600 uppercase tracking-wider mb-3">Cara kerja kami</p>
        <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Nilai-nilai yang mendasari setiap proyek</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {values.map(v => (
          <div class="bg-slate-50 rounded-2xl p-7 border border-slate-100 hover:border-blue-100 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4">
              <div class="w-6 h-6 text-blue-600" set:html={v.icon} />
            </div>
            <h3 class="font-bold text-slate-900 mb-2">{v.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-slate-950">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">Ada proyek yang ingin dibangun?</h2>
      <p class="text-slate-400 mb-8 leading-relaxed">Ceritakan kebutuhan bisnis Anda — kami akan diskusikan solusi yang paling masuk akal dan realistis.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-500 transition-all">
        Hubungi Kami
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </section>
</Layout>
