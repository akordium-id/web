---
import Layout from '../layouts/Layout.astro';
import { stats } from '../data/stats';

const values = [
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: "Terpercaya & Transparan",
    description: "Kami percaya pada komunikasi yang jujur dan terbuka. Tidak ada biaya tersembunyi, tidak ada janji yang tidak bisa kami tepati.",
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: "Berorientasi Hasil",
    description: "Setiap keputusan teknis kami didasarkan pada dampak nyata bagi bisnis Anda — bukan sekadar teknologi yang keren.",
  },
  {
    icon: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: "Kemitraan Jangka Panjang",
    description: "Kami bukan sekadar vendor — kami adalah mitra strategis yang ikut bertumbuh bersama bisnis Anda.",
  },
];

const team = [
  { name: "Arif Nugroho", role: "CEO & Founder", avatar: "AN" },
  { name: "Sinta Permata", role: "Head of Engineering", avatar: "SP" },
  { name: "Dimas Rahardjo", role: "Cloud Architect", avatar: "DR" },
  { name: "Laila Kusuma", role: "Project Manager", avatar: "LK" },
];
---

<Layout title="Tentang Kami — Akordium Lab" description="Kenali Akordium Lab lebih dalam — mitra transformasi digital terpercaya untuk bisnis Indonesia.">
  <!-- Hero -->
  <section class="py-20 lg:py-28 bg-gradient-to-br from-slate-50 to-blue-50/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">Tentang Kami</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
        Kami Membangun Teknologi<br />
        <span class="text-blue-600">yang Benar-benar Bekerja</span>
      </h1>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
        Akordium Lab adalah tim IT profesional yang berdedikasi untuk membantu bisnis Indonesia tumbuh melalui teknologi yang tepat sasaran, efisien, dan andal.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <img
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=700&auto=format&fit=crop&q=80"
            alt="Tim Akordium Lab"
            class="rounded-2xl shadow-2xl shadow-slate-200 w-full h-80 lg:h-[420px] object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <h2 class="text-3xl font-extrabold text-slate-900 mb-5">Cerita Kami</h2>
          <p class="text-slate-600 leading-relaxed mb-4">
            Akordium Lab lahir dari keyakinan bahwa bisnis Indonesia berhak mendapatkan solusi IT yang setara dengan standar global — tanpa harus merogoh kocek enterprise.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Berawal dari tim kecil yang bersemangat, kami telah berkembang menjadi mitra teknologi yang dipercaya oleh puluhan bisnis di seluruh Indonesia — dari startup hingga perusahaan menengah.
          </p>
          <p class="text-slate-500 text-sm leading-relaxed italic">
            Akordium Lab was born from the belief that Indonesian businesses deserve world-class IT solutions — without the enterprise price tag. From a small passionate team, we've grown into a trusted technology partner for dozens of businesses across Indonesia.
          </p>
          <!-- Stats -->
          <div class="grid grid-cols-2 gap-4 mt-8">
            {stats.map(stat => (
              <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                <p class="text-2xl font-extrabold text-blue-600">{stat.value}</p>
                <p class="text-sm text-slate-500 mt-0.5">{stat.labelId}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Nilai-nilai Kami</h2>
        <p class="text-slate-500 max-w-xl mx-auto">Prinsip yang menjadi fondasi setiap keputusan dan layanan yang kami berikan.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {values.map(v => (
          <div class="bg-white rounded-2xl p-7 border border-slate-100 hover:border-blue-100 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4">
              <div class="w-6 h-6 text-blue-600" set:html={v.icon} />
            </div>
            <h3 class="font-bold text-slate-900 mb-2">{v.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Tim Kami</h2>
        <p class="text-slate-500 max-w-xl mx-auto">Para profesional berpengalaman yang siap membantu transformasi digital bisnis Anda.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {team.map(member => (
          <div class="text-center">
            <div class="w-16 h-16 rounded-2xl bg-blue-600 flex items-center justify-center mx-auto mb-3 text-white font-bold text-lg shadow-lg shadow-blue-200">
              {member.avatar}
            </div>
            <h3 class="font-bold text-slate-900 text-sm">{member.name}</h3>
            <p class="text-xs text-slate-500 mt-0.5">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-blue-600">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">Ingin Bergabung atau Berkolaborasi?</h2>
      <p class="text-blue-100 mb-8">Kami selalu terbuka untuk peluang baru — baik sebagai mitra bisnis maupun kolega tim.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-white text-blue-700 font-bold rounded-xl hover:bg-blue-50 transition-all">
        Hubungi Kami
      </a>
    </div>
  </section>
</Layout>
