---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Halaman Tidak Ditemukan | Akordium Lab" description="Halaman yang Anda cari tidak ditemukan.">
  <section class="py-40 bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h1 class="text-6xl sm:text-7xl font-extrabold text-primary-800 mb-4">404</h1>
      <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-4">Halaman tidak ditemukan</h2>
      <p class="text-slate-500 mb-8">
        Maaf, halaman yang Anda kunjungi tidak tersedia atau telah dipindahkan.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-800 text-white font-semibold rounded-xl hover:bg-primary-900 transition-all">
          Kembali ke Beranda
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m0 0l-7 7-7-7M19 14v-4a1 1 0 00-1-1h-3" />
          </svg>
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-slate-300 text-slate-700 font-semibold rounded-xl hover:border-primary-800 hover:text-primary-800 transition-all">
          Hubungi Kami
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>