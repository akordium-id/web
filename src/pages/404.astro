---
import Base from "@/layouts/Base.astro";
import { generatePaths, useTranslations } from "@/lib/utils/i18nUtils";

export function getStaticPaths() {
  return generatePaths();
}

const lang = Astro.currentLocale || "en";
const t = await useTranslations(lang);
---

<Base
  title={t("common.404Heading") || "404 - Page Not Found"}
  description={t("common.404Description") || "The page you're looking for doesn't exist."}
  showHeader={false}
  showFooter={false}
  noIndex
  status={404}
>
  <section class="min-h-screen bg-base flex items-center justify-center px-4">
    <div class="text-center max-w-lg">
      <h1 class="text-9xl font-bold text-primary mb-4">404</h1>
      <h2 class="text-2xl md:text-3xl font-semibold text-primary mb-4">{t("common.404Heading") || "Oops! Page not found"}</h2>
      <p class="text-gray-600 mb-8">{t("common.404Description") || "The page you're looking for doesn't exist or has been moved."}</p>
      <a
        href="/"
        class="inline-flex items-center gap-2 bg-tertiary text-white px-6 py-3 rounded-full hover:bg-tertiary-light transition-colors font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
        {t("common.404ButtonLabel") || "Back to Homepage"}
      </a>
    </div>
  </section>
</Base>
