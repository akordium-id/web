---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services';

const icons: Record<string, string> = {
  code: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  server: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/></svg>`,
  academic: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/></svg>`,
};
---

<Layout title="Layanan Kami — Akordium Lab" description="Solusi IT lengkap dari Akordium Lab: web & app development, infrastructure, dan training untuk bisnis Indonesia.">
  <!-- Hero -->
  <section class="py-20 lg:py-24 bg-gradient-to-br from-slate-50 to-blue-50/30">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-blue-50 text-blue-700 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">Layanan</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
        Solusi IT Kami untuk<br />
        <span class="text-blue-600">Bisnis Anda</span>
      </h1>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto">
        Dari pengembangan aplikasi hingga infrastruktur cloud dan pelatihan tim — kami siap membantu di setiap langkah perjalanan digital Anda.
      </p>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
      {services.map((service, i) => (
        <div id={service.id} class={`grid lg:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
            <div class="w-14 h-14 bg-blue-50 rounded-2xl flex items-center justify-center mb-6">
              <div class="w-7 h-7 text-blue-600" set:html={icons[service.icon]} />
            </div>
            <h2 class="text-3xl font-extrabold text-slate-900 mb-4">{service.titleId}</h2>
            <p class="text-slate-600 leading-relaxed mb-3">{service.descriptionId}</p>
            <p class="text-slate-400 text-sm italic mb-6">{service.description}</p>
            <ul class="space-y-3 mb-8">
              {service.featuresId.map((feat, fi) => (
                <li class="flex items-start gap-3">
                  <div class="w-5 h-5 bg-blue-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                  <div>
                    <span class="text-slate-700 font-medium text-sm">{feat}</span>
                    <span class="text-slate-400 text-xs italic ml-2">({service.features[fi]})</span>
                  </div>
                </li>
              ))}
            </ul>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-all">
              Mulai Sekarang
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
            <div class="bg-slate-50 rounded-2xl p-8 border border-slate-100 h-64 lg:h-80 flex items-center justify-center">
              <div class="w-24 h-24 bg-blue-100 rounded-3xl flex items-center justify-center">
                <div class="w-12 h-12 text-blue-500" set:html={icons[service.icon]} />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-slate-900">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">Tidak Yakin Layanan Mana yang Cocok?</h2>
      <p class="text-slate-400 mb-8">Tim kami siap membantu Anda menemukan solusi yang paling tepat. Konsultasi pertama gratis.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-all">
        Konsultasi Gratis
      </a>
    </div>
  </section>
</Layout>
