---
import Layout from '../../layouts/Layout.astro';
import { services } from '../../data/services';

const icons: Record<string, string> = {
  globe: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  chart: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  cog: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
};

const servicePlaceholderImages = [
  'https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=1400&q=80',
  'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?auto=format&fit=crop&w=1400&q=80',
  'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?auto=format&fit=crop&w=1400&q=80',
];
---

<Layout title="Layanan | Akordium Lab" description="Solusi web untuk bisnis kecil-menengah: website company profile, dashboard internal, dan management information system yang praktis.">
  <!-- Hero -->
  <section class="py-20 lg:py-24 bg-gradient-to-br from-stone-50 to-rose-50/20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 bg-rose-50 text-rose-800 text-xs font-semibold rounded-full uppercase tracking-wider mb-4">Layanan</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
        Solusi web untuk bisnis<br />
        <span class="text-rose-800">yang lebih tertata</span>
      </h1>
      <p class="text-lg text-slate-500 max-w-2xl mx-auto">
        Kami membangun website dan sistem informasi yang praktis, terstruktur, dan mudah dipakai sehari-hari oleh tim Anda.
      </p>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-20">
      {services.map((service, i) => (
        <div id={service.id} class={`grid lg:grid-cols-2 gap-12 items-center ${i % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <div class={i % 2 === 1 ? 'lg:order-2' : ''}>
            <div class="w-14 h-14 bg-rose-50 rounded-2xl flex items-center justify-center mb-6">
              <div class="w-7 h-7 text-rose-800" set:html={icons[service.icon]} />
            </div>
            <h2 class="text-3xl font-extrabold text-slate-900 mb-4">{service.title}</h2>
            <p class="text-slate-600 leading-relaxed mb-6">{service.description}</p>
            <ul class="space-y-3 mb-8">
              {service.features.map((feat) => (
                <li class="flex items-start gap-3">
                  <div class="w-5 h-5 bg-rose-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-rose-800" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                  <span class="text-slate-700 text-sm">{feat}</span>
                </li>
              ))}
            </ul>
            <a href="/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-rose-800 text-white font-semibold rounded-xl hover:bg-rose-900 transition-all">
              Mulai Sekarang
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          <div class={i % 2 === 1 ? 'lg:order-1' : ''}>
            <div class="relative bg-stone-50 rounded-2xl border border-stone-100 overflow-hidden h-64 lg:h-80">
              <img
                src={servicePlaceholderImages[i % servicePlaceholderImages.length]}
                alt={`Ilustrasi untuk layanan ${service.title}`}
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-[#2f1d1b]/40 via-transparent to-transparent"></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-slate-900">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4">Tidak yakin mulai dari mana?</h2>
      <p class="text-slate-400 mb-8">Tim kami siap membantu Anda menemukan solusi yang paling sesuai dengan kebutuhan bisnis.</p>
      <a href="/contact" class="inline-flex items-center gap-2 px-7 py-3.5 bg-rose-800 text-white font-bold rounded-xl hover:bg-rose-700 transition-all">
        Jadwalkan konsultasi
      </a>
    </div>
  </section>
</Layout>
